#!/bin/bash

set -e

WORK_DUMP=""
PERSONAL_DUMP=""

for arg in "$@"; do
  case $arg in
    --work-dump=*) WORK_DUMP="${arg#*=}" ;;
    --personal-dump=*) PERSONAL_DUMP="${arg#*=}" ;;
    -h|--help)
      echo "Usage: $0 --work-dump=<file> --personal-dump=<file>"
      exit 0
      ;;
    *)
      echo "error: unknown argument: $arg" >&2
      exit 1
      ;;
  esac
done

if [[ -z "$WORK_DUMP" || -z "$PERSONAL_DUMP" ]]; then
  echo "Usage: $0 --work-dump=<file> --personal-dump=<file>" >&2
  exit 1
fi

for f in "$WORK_DUMP" "$PERSONAL_DUMP"; do
  if [[ ! -f "$f" ]]; then
    echo "error: file not found: $f" >&2
    exit 1
  fi
done

REPO_ROOT="${BASH_SOURCE%/*}/.."
OUTPUT_DIR="$REPO_ROOT/aspects/homebrew/files"

SCRATCH=$(mktemp -d)
trap 'rm -rf "$SCRATCH"' EXIT

for prefix in work personal; do
  for type in taps brew cask cargo go; do
    > "$SCRATCH/${prefix}_${type}"
  done
done
> "$SCRATCH/tap_urls"
> "$SCRATCH/restart_service"
> "$SCRATCH/args_head"

parse_dump() {
  local file=$1
  local prefix=$2

  while IFS= read -r line; do
    [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue

    if [[ "$line" =~ ^tap\ \"([^\"]+)\" ]]; then
      local name="${BASH_REMATCH[1]}"
      echo "$name" >> "$SCRATCH/${prefix}_taps"
      local rest="${line#*\"$name\"}"
      if [[ "$rest" =~ ,\ \"([^\"]+)\" ]]; then
        printf '%s\t%s\n' "$name" "${BASH_REMATCH[1]}" >> "$SCRATCH/tap_urls"
      fi

    elif [[ "$line" =~ ^brew\ \"([^\"]+)\" ]]; then
      local name="${BASH_REMATCH[1]}"
      if [[ "$name" =~ ^([^/]+/[^/]+)/(.+)$ ]]; then
        echo "${BASH_REMATCH[1]}" >> "$SCRATCH/${prefix}_taps"
        name="${BASH_REMATCH[2]}"
      fi
      echo "$name" >> "$SCRATCH/${prefix}_brew"
      if [[ "$line" =~ restart_service ]]; then
        echo "$name" >> "$SCRATCH/restart_service"
      fi
      if [[ "$line" =~ args:.*HEAD ]]; then
        echo "$name" >> "$SCRATCH/args_head"
      fi

    elif [[ "$line" =~ ^cask\ \"([^\"]+)\" ]]; then
      local name="${BASH_REMATCH[1]}"
      if [[ "$name" =~ ^([^/]+/[^/]+)/(.+)$ ]]; then
        echo "${BASH_REMATCH[1]}" >> "$SCRATCH/${prefix}_taps"
        name="${BASH_REMATCH[2]}"
      fi
      echo "$name" >> "$SCRATCH/${prefix}_cask"

    elif [[ "$line" =~ ^cargo\ \"([^\"]+)\" ]]; then
      echo "${BASH_REMATCH[1]}" >> "$SCRATCH/${prefix}_cargo"

    elif [[ "$line" =~ ^go\ \"([^\"]+)\" ]]; then
      echo "${BASH_REMATCH[1]}" >> "$SCRATCH/${prefix}_go"
    fi
  done < "$file"

  for type in taps brew cask cargo go; do
    LC_ALL=C sort -u "$SCRATCH/${prefix}_${type}" -o "$SCRATCH/${prefix}_${type}"
  done
}

echo "Parsing dump files..." >&2
parse_dump "$WORK_DUMP" "work"
parse_dump "$PERSONAL_DUMP" "personal"

LC_ALL=C sort -u "$SCRATCH/restart_service" -o "$SCRATCH/restart_service"
LC_ALL=C sort -u "$SCRATCH/args_head" -o "$SCRATCH/args_head"
LC_ALL=C sort -u "$SCRATCH/tap_urls" -o "$SCRATCH/tap_urls"

for type in taps brew cask cargo go; do
  comm -12 "$SCRATCH/work_${type}" "$SCRATCH/personal_${type}" > "$SCRATCH/common_${type}"
  comm -23 "$SCRATCH/work_${type}" "$SCRATCH/personal_${type}" > "$SCRATCH/work_only_${type}"
  comm -13 "$SCRATCH/work_${type}" "$SCRATCH/personal_${type}" > "$SCRATCH/personal_only_${type}"
done

# Always include these common taps.
for tap in "homebrew/bundle" "homebrew/services"; do
  if ! grep -qx "$tap" "$SCRATCH/common_taps" 2>/dev/null; then
    echo "$tap" >> "$SCRATCH/common_taps"
  fi
  for set in work_only personal_only; do
    if grep -qx "$tap" "$SCRATCH/${set}_taps" 2>/dev/null; then
      grep -vx "$tap" "$SCRATCH/${set}_taps" > "$SCRATCH/${set}_taps.tmp"
      mv "$SCRATCH/${set}_taps.tmp" "$SCRATCH/${set}_taps"
    fi
  done
done
LC_ALL=C sort -u "$SCRATCH/common_taps" -o "$SCRATCH/common_taps"

# Fetch descriptions for formulae and casks.
cat "$SCRATCH/common_brew" "$SCRATCH/work_only_brew" "$SCRATCH/personal_only_brew" \
  | LC_ALL=C sort -u > "$SCRATCH/all_brew"
cat "$SCRATCH/common_cask" "$SCRATCH/work_only_cask" "$SCRATCH/personal_only_cask" \
  | LC_ALL=C sort -u > "$SCRATCH/all_cask"

> "$SCRATCH/formula_descs"
> "$SCRATCH/cask_descs"

echo "Fetching installed package descriptions..." >&2
brew info --json=v2 --installed > "$SCRATCH/installed_info.json" 2>/dev/null || true
jq -r '.formulae[] | "\(.name)\t\(.desc // "")"' "$SCRATCH/installed_info.json" \
  >> "$SCRATCH/formula_descs" 2>/dev/null || true
jq -r '.casks[] | "\(.token)\t\(.desc // "")"' "$SCRATCH/installed_info.json" \
  >> "$SCRATCH/cask_descs" 2>/dev/null || true

# Find formulae/casks still missing descriptions and look them up individually.
fetch_missing() {
  local type=$1
  local names_file=$2
  local descs_file=$3
  local json_key=$4
  local name_field=$5

  comm -23 "$names_file" <(cut -f1 "$descs_file" | LC_ALL=C sort -u) > "$SCRATCH/missing_${type}"
  [[ ! -s "$SCRATCH/missing_${type}" ]] && return

  local total count
  total=$(wc -l < "$SCRATCH/missing_${type}" | tr -d ' ')
  echo "Fetching descriptions for $total uninstalled ${type}s..." >&2
  count=0
  while read -r name; do
    count=$((count + 1))
    printf '\r  %d/%d' "$count" "$total" >&2
    local desc
    desc=$(brew info --json=v2 "--${type}" "$name" 2>/dev/null \
      | jq -r ".${json_key}[0].${name_field} // \"\"" 2>/dev/null || true)
    printf '%s\t%s\n' "$name" "$desc" >> "$descs_file"
  done < "$SCRATCH/missing_${type}"
  echo >&2
}

fetch_missing "formula" "$SCRATCH/all_brew" "$SCRATCH/formula_descs" "formulae" "desc"
fetch_missing "cask" "$SCRATCH/all_cask" "$SCRATCH/cask_descs" "casks" "desc"

# Output helpers.
get_desc() {
  local name=$1 descs_file=$2
  grep "^${name}	" "$descs_file" 2>/dev/null | head -1 | cut -f2-
}

format_tap() {
  local name=$1
  local url
  url=$(grep "^${name}	" "$SCRATCH/tap_urls" 2>/dev/null | head -1 | cut -f2-)
  if [[ -n "$url" ]]; then
    echo "tap \"$name\", \"$url\""
  else
    echo "tap \"$name\""
  fi
}

format_brew() {
  local name=$1
  local line="brew \"$name\""
  if grep -qx "$name" "$SCRATCH/restart_service" 2>/dev/null; then
    line="$line, restart_service: true"
  fi
  if grep -qx "$name" "$SCRATCH/args_head" 2>/dev/null; then
    line="$line, args: [\"HEAD\"]"
  fi
  local desc
  desc=$(get_desc "$name" "$SCRATCH/formula_descs")
  if [[ -n "$desc" ]]; then
    line="$line # \"$desc\""
  fi
  echo "$line"
}

format_cask() {
  local name=$1
  local line="cask \"$name\""
  local desc
  desc=$(get_desc "$name" "$SCRATCH/cask_descs")
  if [[ -n "$desc" ]]; then
    line="$line # \"$desc\""
  fi
  echo "$line"
}

format_cargo() {
  echo "cargo \"$1\""
}

format_go() {
  echo "go \"$1\""
}

file_header() {
  cat <<'EOF'
# vim: set nomodifiable : DO NOT EDIT - regenerate with:
#
# ```
# bin/brew-bundle-dump --work-dump=<work-dump> --personal-dump=<personal-dump>
# ```
EOF
}

mkdir -p "$OUTPUT_DIR"

echo "Writing Brewfiles..." >&2

# --- Brewfile (common) ---
{
  file_header
  echo ""
  echo 'cask_args appdir: "/Applications"'
  echo ""
  while read -r tap; do format_tap "$tap"; done < "$SCRATCH/common_taps"
  if [[ -s "$SCRATCH/common_brew" ]]; then
    echo ""
    echo "# Packages."
    while read -r name; do format_brew "$name"; done < "$SCRATCH/common_brew"
  fi
  if [[ -s "$SCRATCH/common_cask" ]]; then
    echo ""
    echo "# Casks."
    while read -r name; do format_cask "$name"; done < "$SCRATCH/common_cask"
  fi
  if [[ -s "$SCRATCH/common_cargo" ]]; then
    echo ""
    echo "# Cargo packages."
    while read -r name; do format_cargo "$name"; done < "$SCRATCH/common_cargo"
  fi
  if [[ -s "$SCRATCH/common_go" ]]; then
    echo ""
    echo "# Go packages."
    while read -r name; do format_go "$name"; done < "$SCRATCH/common_go"
  fi
} > "$OUTPUT_DIR/Brewfile"
echo "  wrote Brewfile" >&2

# --- Profile-specific Brewfiles ---
for profile in personal work; do
  has_content=false
  for type in taps brew cask cargo go; do
    [[ -s "$SCRATCH/${profile}_only_${type}" ]] && has_content=true
  done
  $has_content || continue

  {
    file_header
    if [[ -s "$SCRATCH/${profile}_only_cask" ]]; then
      echo ""
      echo 'cask_args appdir: "/Applications"'
    fi
    if [[ -s "$SCRATCH/${profile}_only_taps" ]]; then
      echo ""
      while read -r tap; do format_tap "$tap"; done < "$SCRATCH/${profile}_only_taps"
    fi
    if [[ -s "$SCRATCH/${profile}_only_brew" ]]; then
      echo ""
      echo "# Packages."
      while read -r name; do format_brew "$name"; done < "$SCRATCH/${profile}_only_brew"
    fi
    if [[ -s "$SCRATCH/${profile}_only_cask" ]]; then
      echo ""
      echo "# Casks."
      while read -r name; do format_cask "$name"; done < "$SCRATCH/${profile}_only_cask"
    fi
    if [[ -s "$SCRATCH/${profile}_only_cargo" ]]; then
      echo ""
      echo "# Cargo packages."
      while read -r name; do format_cargo "$name"; done < "$SCRATCH/${profile}_only_cargo"
    fi
    if [[ -s "$SCRATCH/${profile}_only_go" ]]; then
      echo ""
      echo "# Go packages."
      while read -r name; do format_go "$name"; done < "$SCRATCH/${profile}_only_go"
    fi
  } > "$OUTPUT_DIR/Brewfile.${profile}"
  echo "  wrote Brewfile.${profile}" >&2
done

echo "Done." >&2
