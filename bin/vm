#!/bin/bash

set -e

REPO_ROOT="${BASH_SOURCE%/*}/.."

source "$REPO_ROOT/bin/common"

VM_BASE="wincent-base"
VM_USER="admin"
VM_PASS="admin"
VM_REPO_PATH="/home/$VM_USER/code/wincent"
OCI_IMAGE="ghcr.io/cirruslabs/ubuntu:latest"
REGISTRY="ghcr.io/wincent/wincent-base:latest"

SSH_OPTIONS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR"

vm_ssh() {
  sshpass -p "$VM_PASS" ssh $SSH_OPTIONS "$VM_USER@$VM_IP" "$@"
}

wait_for_ssh() {
  log_info "Waiting for SSH..."
  local retries=30
  while [ $retries -gt 0 ]; do
    if vm_ssh true 2>/dev/null; then
      log_info "SSH is available"
      return 0
    fi
    retries=$((retries - 1))
    sleep 2
  done
  log_error "Timed out waiting for SSH"
  exit 1
}

cmd_create() {
  if tart list | grep -q "^local[[:space:]]*$VM_BASE "; then
    log_error "VM '$VM_BASE' already exists; destroy it first with: bin/vm destroy"
    exit 1
  fi

  log_info "Cloning $OCI_IMAGE -> $VM_BASE"
  tart clone "$OCI_IMAGE" "$VM_BASE"

  log_info "Configuring VM resources"
  tart set "$VM_BASE" --disk-size 50 --cpu 4 --memory 8192

  log_info "Starting VM (headless)"
  tart run "$VM_BASE" --no-graphics &
  TART_PID=$!

  trap 'log_info "Stopping VM"; tart stop "$VM_BASE" 2>/dev/null; wait $TART_PID 2>/dev/null' EXIT

  VM_IP=$(tart ip "$VM_BASE" --wait 30)
  log_info "VM IP: $VM_IP"

  wait_for_ssh

  log_info "Installing prerequisites"
  vm_ssh "sudo apt-get update && sudo apt-get install -y git curl"

  log_info "Initializing repo on VM"
  vm_ssh "mkdir -p $VM_REPO_PATH && cd $VM_REPO_PATH && git init -b main && git config receive.denyCurrentBranch updateInstead"

  log_info "Pushing repo to VM"
  GIT_SSH_COMMAND="sshpass -p $VM_PASS ssh $SSH_OPTIONS" \
    git -C "$REPO_ROOT" push "ssh://$VM_USER@$VM_IP$VM_REPO_PATH" HEAD:refs/heads/main

  log_info "Checking out and running install"
  vm_ssh "cd $VM_REPO_PATH && git checkout main && FIG_IDENTITY=wincent SUDO_ASKPASS=echo ./install"

  log_info "Base image '$VM_BASE' is ready"
  log_info "Clone it with: bin/vm clone <name>"
}

cmd_clone() {
  if [ -z "$1" ]; then
    log_error "Usage: bin/vm clone <vm-name>"
    exit 1
  fi

  local vm_name="$1"
  local clone_source

  if tart list | grep -q "^local[[:space:]]*$VM_BASE "; then
    clone_source="$VM_BASE"
  elif tart list | grep -q "^OCI[[:space:]]*$REGISTRY "; then
    clone_source="$REGISTRY"
  else
    log_error "Base image '$VM_BASE' not found; create it with: bin/vm create (or pull it with: bin/vm pull)"
    exit 1
  fi

  log_info "Cloning $clone_source -> $vm_name"
  tart clone "$clone_source" "$vm_name"

  log_info "VM '$vm_name' is ready"
  log_info "Start it with:  bin/vm start $vm_name"
  log_info "Connect with:   bin/vm ssh $vm_name"
}

cmd_push() {
  if ! tart list --format json | jq -e --arg name "$VM_BASE" '.[] | select(.Name == $name)' &>/dev/null; then
    log_error "VM '$VM_BASE' not found; create it first with: bin/vm create"
    exit 1
  fi

  if tart list --format json | jq -e --arg name "$VM_BASE" '.[] | select(.Name == $name and .State == "running")' &>/dev/null; then
    log_error "VM '$VM_BASE' is running; stop it first with: bin/vm stop"
    exit 1
  fi

  log_info "Pushing $VM_BASE -> $REGISTRY"
  if ! tart push "$VM_BASE" "$REGISTRY"; then
    log_error "Push failed; you may need to run: \`tart login ghcr.io\` (use a GitHub PAT with \`write:packages\` scope as the password)"
    exit 1
  fi

  log_info "Pushed successfully"
  log_info "Pull with: bin/vm pull"
}

cmd_pull() {
  log_info "Pulling $REGISTRY"
  if ! tart pull "$REGISTRY"; then
    log_error "Pull failed; you may need to run: \`tart login ghcr.io\` (use a GitHub PAT with \`read:packages\` scope as the password)"
    exit 1
  fi

  log_info "Pulled successfully"
  log_info "Clone it with: bin/vm clone <name>"
}

cmd_destroy() {
  local vm_name="${1:-$VM_BASE}"
  tart stop "$vm_name" 2>/dev/null || true
  tart delete "$vm_name"
}

cmd_start() {
  local vm_name="${1:-$VM_BASE}"
  if [ "$vm_name" = "--background" ]; then
    vm_name="$VM_BASE"
    tart run "$vm_name" --no-graphics &
    disown
    log_info "VM started in background (PID $!)"
  elif [ "${2:-}" = "--background" ]; then
    tart run "$vm_name" --no-graphics &
    disown
    log_info "VM started in background (PID $!)"
  else
    log_info "Running in foreground (pass \`--background\` to run in the background)"
    tart run "$vm_name" --no-graphics
  fi
}

cmd_ssh() {
  local vm_name="${1:-$VM_BASE}"
  VM_IP=$(tart ip "$vm_name" --wait 30)
  sshpass -p "$VM_PASS" ssh $SSH_OPTIONS "$VM_USER@$VM_IP"
}

cmd_stop() {
  local vm_name="${1:-$VM_BASE}"
  tart stop "$vm_name"
}

cmd_help() {
  cat <<EOF
Usage: bin/vm <command> [options]

Commands:
  clone <name>            Clone the base image to create a new VM
  create                  Create a new base image from
                          ${OCI_IMAGE}
  destroy [name]          Stop and delete a VM (default: wincent-base)
  help                    Show this help message
  pull                    Pull the base image from the registry
  push                    Push the base image to the registry
  start [name] [--background]
                          Start a VM (default: wincent-base)
  ssh [name]              Connect to a running VM via SSH (default: wincent-base)
  stop [name]             Stop a running VM (default: wincent-base)
EOF
}

case "${1:-}" in
  clone)
    shift
    cmd_clone "$@"
    ;;
  create)
    shift
    cmd_create "$@"
    ;;
  destroy)
    shift
    cmd_destroy "$@"
    ;;
  help|--help)
    cmd_help
    ;;
  pull)
    shift
    cmd_pull "$@"
    ;;
  push)
    shift
    cmd_push "$@"
    ;;
  start)
    shift
    cmd_start "$@"
    ;;
  ssh)
    shift
    cmd_ssh "$@"
    ;;
  stop)
    shift
    cmd_stop "$@"
    ;;
  *)
    cmd_help
    exit 1
    ;;
esac
