{
  "cleanupPeriodDays": 99999,
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "max"
  },
  "permissions": {
    "allow": [
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(jj diff:*)",
      "Bash(jj evolog:*)",
      "Bash(jj gr:*)",
      "Bash(jj last:*)",
      "Bash(jj log:*)",
      "Bash(jj o:*)",
      "Bash(jj oo:*)",
      "Bash(jj op log:*)",
      "Bash(jj st:*)",
      "Bash(jj status:*)",
      "Bash(jj show:*)",
      "Skill(commit)",
      "Skill(jujutsu)"
    ],
    "deny": []
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-notify-hook"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "claude-pre-tool-use-hook"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "claude-post-tool-use-hook"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-stop-hook"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.zsh/bin/claude-statusline",
    "padding": 0
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "meme@wincent-claude-plugins": true,
    "session@wincent-claude-plugins": true,
    "git@wincent-claude-plugins": true,
    "jj@wincent-claude-plugins": true,
    "shannon@wincent-claude-plugins": true,
    "pr@wincent-claude-plugins": true
  },
  "extraKnownMarketplaces": {
    "wincent-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "wincent/wincent-claude-plugins"
      },
      "autoUpdate": true
    }
  },
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Processing"
    ]
  },
  "alwaysThinkingEnabled": true
}
