# "tick" by incrementing GIT_AUTHOR_DATE and GIT_COMMITTER_DATE.
function tick() {
  emulate -L zsh
  zmodload zsh/datetime # For strftime.

  if [ -z "$GIT_AUTHOR_DATE" -o -z "$GIT_COMMITTER_DATE" ]; then
    tw "$@"
  else
    # Fragile assumption: dates are in format produced by `tw`/`ts`.
    local TIMESTAMP=$(expr \
      $(echo $GIT_AUTHOR_DATE | cut -d ' ' -f 1) \
      $(parseoffset "$@") \
    )
    local OFFSET=$(date +%z)
    local HUMAN=$(strftime '%a %d %b %Y %H:%M:%S %Z' $TIMESTAMP)
    echo "Bumping timestamp to: $TIMESTAMP $OFFSET ($HUMAN $OFFSET)"
    export GIT_AUTHOR_DATE="$TIMESTAMP $OFFSET"
    export GIT_COMMITTER_DATE="$TIMESTAMP $OFFSET"
    export TW="$*"
  fi
}
