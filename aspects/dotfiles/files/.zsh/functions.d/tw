# "[t]ime[w]arp" by setting GIT_AUTHOR_DATE and GIT_COMMITTER_DATE.
function tw() {
  emulate -L zsh
  zmodload zsh/datetime # For strftime.

  local TIMESTAMP=$(ts "$@" 2> /dev/null)
  local OFFSET=$(date +%z)
  local HUMAN=$(strftime '%a %d %b %Y %H:%M:%S %Z' $TIMESTAMP)
  echo "Spawning subshell with timestamp: $TIMESTAMP $OFFSET ($HUMAN $OFFSET)"
  env GIT_AUTHOR_DATE="$TIMESTAMP $OFFSET" GIT_COMMITTER_DATE="$TIMESTAMP $OFFSET" TW="$*" zsh
}
