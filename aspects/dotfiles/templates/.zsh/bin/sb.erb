#!/bin/bash
# <%= variables.figManaged %>

set -euo pipefail

# --- Find project root ---

find_root() {
    local dir
    dir="$(pwd -P)"
    while [ "$dir" != "/" ]; do
        if [ -f "$dir/.sandboxrc" ] || [ -e "$dir/.git" ] || [ -d "$dir/.jj" ]; then
            echo "$dir"
            return
        fi
        dir="$(dirname "$dir")"
    done
    echo "$dir"
}

PROJECT_ROOT="$(find_root)"
PROJECT_NAME="$(basename "$PROJECT_ROOT")"

# --- Defaults ---

SB_BRANCHES=(main)
SB_WORKTREES=()
SB_PORTS=()
SB_SOCKETS=("$HOME/.clipper.sock:/home/admin/.clipper.sock")
SB_REPO_SUBDIR="code"
SB_VM_CPU=4
SB_VM_MEMORY=8192
SB_VM_IMAGE="<%= variables.sbVmImage %>"

VM_USER="admin"
VM_PASS="admin"
SSH_OPTS=(-o StrictHostKeyChecking=no -o ConnectTimeout=5 -o ControlPath=none -o SendEnv=ANTHROPIC_API_KEY -o SendEnv=CLAUDE_CODE_OAUTH_TOKEN -o SendEnv=KAGI_API_TOKEN -o SendEnv=LANG -o 'SendEnv=LC_*')

# --- Helpers (available to .sandboxrc) ---

sb_ssh() {
    sshpass -p "$VM_PASS" ssh "${SSH_OPTS[@]}" "$VM_USER@$1" "${@:2}"
}

sb_scp() {
    sshpass -p "$VM_PASS" scp "${SSH_OPTS[@]}" "$@"
}

# --- Source config ---

find_sandboxrc() {
    if [ -f "$PROJECT_ROOT/.sandboxrc" ]; then
        echo "$PROJECT_ROOT/.sandboxrc"
        return
    fi
    if [ -n "${SB_CONFIG_PATH:-}" ]; then
        local rel="${PROJECT_ROOT#"$HOME"/}"
        rel="${rel#/}"
        local IFS=':'
        local dir
        for dir in $SB_CONFIG_PATH; do
            if [ -f "$dir/$rel/sandboxrc" ]; then
                echo "$dir/$rel/sandboxrc"
                return
            fi
        done
    fi
}

sandboxrc="$(find_sandboxrc)"
if [ -n "$sandboxrc" ]; then
    # shellcheck disable=SC1091
    source "$sandboxrc"
fi

# --- Derived ---

VM_NAME="${PROJECT_NAME}-sandbox"
VM_REPO_PATH="/home/$VM_USER/$SB_REPO_SUBDIR/$PROJECT_NAME"
SB_SSH_EXEC="${SB_SSH_EXEC-cd $SB_REPO_SUBDIR/$PROJECT_NAME && exec zsh -l}"

# --- Internal helpers ---

vm_exists() {
    tart list --format json | jq -e --arg name "$VM_NAME" '.[] | select(.Name == $name)' &>/dev/null
}

vm_running() {
    tart list --format json | jq -e --arg name "$VM_NAME" '.[] | select(.Name == $name and .State == "running")' &>/dev/null
}

vm_ip() {
    tart ip "$VM_NAME"
}

wait_for_ip() {
    echo "Waiting for VM IP..." >&2
    local ip
    if ! ip="$(tart ip "$VM_NAME" --wait 120)"; then
        echo "Error: timed out waiting for VM IP" >&2
        exit 1
    fi
    echo "$ip"
}

wait_for_ssh() {
    local ip="$1"
    echo "Waiting for SSH..." >&2
    local attempts=0
    while ! sb_ssh "$ip" true &>/dev/null; do
        attempts=$((attempts + 1))
        if [ "$attempts" -ge 30 ]; then
            echo "Error: timed out waiting for SSH" >&2
            exit 1
        fi
        sleep 2
    done
}

provision() {
    local ip="$1"

    echo "Configuring git identity..."
    local host_name host_email vm_hostname
    host_name="$(git config user.name)"
    host_email="$(git config user.email)"
    vm_hostname="$(sb_ssh "$ip" hostname)"
    sb_ssh "$ip" "git config --file ~/.config/git/host/$vm_hostname user.name $(printf '%q' "$host_name") && git config --file ~/.config/git/host/$vm_hostname user.email $(printf '%q' "$host_email")"

    if type sb_provision &>/dev/null; then
        echo "Running project-specific provisioning..."
        sb_provision "$ip"
    fi
}

init_repo() {
    local ip="$1"
    local primary="${SB_BRANCHES[0]}"
    local parent
    parent="$(dirname "$VM_REPO_PATH")"
    echo "Initializing repo in VM..."
    sb_ssh "$ip" "mkdir -p $parent && git init --initial-branch=$primary $VM_REPO_PATH && cd $VM_REPO_PATH && git config receive.denyCurrentBranch updateInstead"
}

configure_claude() {
    local ip="$1"

    echo "Configuring Claude..."
    sb_ssh "$ip" 'mkdir -p ~/.claude && cat > ~/.claude.json <<EOF
{"hasCompletedOnboarding": true}
EOF'
}

setup_git_remote() {
    local ip="$1"
    export GIT_SSH_COMMAND="sshpass -p $VM_PASS ssh ${SSH_OPTS[*]}"
    git -C "$PROJECT_ROOT" remote remove vm 2>/dev/null || true
    git -C "$PROJECT_ROOT" remote add vm "ssh://${VM_USER}@${ip}${VM_REPO_PATH}"
}

# --- Commands ---

cmd_create() {
    if vm_exists; then
        echo "Error: VM '$VM_NAME' already exists."
        echo "Use 'sb destroy' first, or 'sb reset' to recreate."
        exit 1
    fi

    local clone_source="$SB_VM_IMAGE"
    local local_base="${SB_VM_IMAGE##*/}"
    local_base="${local_base%%:*}"

    if [ "$USE_REGISTRY" = false ] && tart list | grep -q "^local[[:space:]]*${local_base} "; then
        clone_source="$local_base"
        echo "Using local $local_base image; run with --use-registry to use remote $SB_VM_IMAGE image"
    else
        echo "Using image previously fetched from $SB_VM_IMAGE; use \`sb pull\` to obtain a newer image if desired"
    fi

    echo "Cloning VM image..."
    tart clone "$clone_source" "$VM_NAME"

    echo "Configuring VM resources..."
    tart set "$VM_NAME" --cpu "$SB_VM_CPU" --memory "$SB_VM_MEMORY"

    echo "Starting VM..."
    tart run --no-graphics "$VM_NAME" &

    local ip
    ip="$(wait_for_ip)"
    echo "VM IP: $ip"

    wait_for_ssh "$ip"

    provision "$ip"
    init_repo "$ip"
    configure_claude "$ip"

    echo "Injecting code..."
    cmd_inject

    echo ""
    echo "VM '$VM_NAME' is ready."
    echo "Connect with: sb ssh"
}

cmd_ssh() {
    local ip
    ip="$(vm_ip)"
    local port_args=()
    for port in "${SB_PORTS[@]+"${SB_PORTS[@]}"}"; do
        local host_port="${port%%:*}"
        local vm_port="${port##*:}"
        port_args+=(-L "$host_port:localhost:$vm_port")
    done
    local socket_args=()
    for sock in "${SB_SOCKETS[@]+"${SB_SOCKETS[@]}"}"; do
        local host_sock="${sock%%:*}"
        local vm_sock="${sock##*:}"
        socket_args+=(-R "$vm_sock:$host_sock")
    done
    local cmd_args=()
    if [ $# -gt 0 ]; then
        cmd_args=("$@")
    elif [ -n "$SB_SSH_EXEC" ]; then
        cmd_args=(-t "$SB_SSH_EXEC")
    fi
    exec sshpass -p "$VM_PASS" ssh "${SSH_OPTS[@]}" \
        "${port_args[@]+"${port_args[@]}"}" \
        "${socket_args[@]+"${socket_args[@]}"}" \
        "$VM_USER@$ip" "${cmd_args[@]+"${cmd_args[@]}"}"
}

cmd_scp() {
    local ip
    ip="$(vm_ip)" || {
        echo "Error: VM is not running."
        exit 1
    }

    local args=()
    for arg in "$@"; do
        if [[ "$arg" == vm:* ]]; then
            args+=("$VM_USER@$ip:${arg#vm:}")
        else
            args+=("$arg")
        fi
    done

    sb_scp "${args[@]}"
}

cmd_destroy() {
    tart stop "$VM_NAME" 2>/dev/null || true
    tart delete "$VM_NAME" 2>/dev/null || true
    git -C "$PROJECT_ROOT" remote remove vm 2>/dev/null || true
    echo "VM '$VM_NAME' destroyed."
}

cmd_reset() {
    cmd_destroy
    cmd_create
}

cmd_stop() {
    tart stop "$VM_NAME"
}

cmd_start() {
    if vm_running; then
        echo "VM '$VM_NAME' is already running."
        return
    fi

    echo "Starting VM..."
    tart run --no-graphics "$VM_NAME" &

    local ip
    ip="$(wait_for_ip)"
    echo "VM IP: $ip"

    wait_for_ssh "$ip"
    echo "VM '$VM_NAME' is ready."
}

cmd_restart() {
    cmd_stop 2>/dev/null || true
    cmd_start
}

cmd_pull() {
    local local_base="${SB_VM_IMAGE##*/}"
    local_base="${local_base%%:*}"

    if tart list --format json | jq -e --arg name "$local_base" '.[] | select(.Name == $name and .State == "running")' &>/dev/null; then
        echo "Error: local '$local_base' is running; stop it first."
        exit 1
    fi

    echo "Pulling $SB_VM_IMAGE..."
    tart pull "$SB_VM_IMAGE"

    if tart list | grep -q "^local[[:space:]]*${local_base} "; then
        echo "Deleting local $local_base to replace with pulled image..."
        tart delete "$local_base"
    fi

    echo "Cloning $SB_VM_IMAGE -> $local_base..."
    tart clone "$SB_VM_IMAGE" "$local_base"
}

cmd_status() {
    if ! vm_exists; then
        echo "VM '$VM_NAME' does not exist."
        echo "Create with: sb create"
        return
    fi

    if vm_running; then
        echo "VM '$VM_NAME' is running."
        local ip
        if ip="$(vm_ip 2>/dev/null)"; then
            echo "IP: $ip"
        else
            echo "IP: (not yet available)"
        fi
    else
        echo "VM '$VM_NAME' exists but is not running."
        echo "Start with: sb start"
    fi
}

cmd_ip() {
    vm_ip
}

cmd_list() {
    tart list
}

cmd_inject() {
    local force=false
    local branches=()
    for arg in "$@"; do
        if [ "$arg" = "--force" ] || [ "$arg" = "-f" ]; then
            force=true
        else
            branches+=("$arg")
        fi
    done
    if [ ${#branches[@]} -eq 0 ]; then
        branches=("${SB_BRANCHES[@]}")
    fi

    local ip
    ip="$(vm_ip)" || {
        echo "Error: VM is not running."
        exit 1
    }

    setup_git_remote "$ip"

    local has_commits
    has_commits=$(sb_ssh "$ip" "cd $VM_REPO_PATH && git rev-parse HEAD >/dev/null 2>&1 && echo yes || echo no")

    if [ "$has_commits" = "yes" ]; then
        echo "Checking for uncommitted changes in VM..."
        if ! sb_ssh "$ip" "cd $VM_REPO_PATH && git diff --quiet HEAD && git diff --quiet --cached" 2>/dev/null; then
            echo "Warning: VM repo has uncommitted changes."
            read -r -p "Continue anyway? [y/N] " answer
            if [[ ! "$answer" =~ ^[Yy]$ ]]; then
                exit 1
            fi
        fi
    fi

    echo "Pushing ${branches[*]} to VM..."
    if [ "$force" = true ]; then
        git -C "$PROJECT_ROOT" push --force vm "${branches[@]}"
    else
        if ! git -C "$PROJECT_ROOT" push vm "${branches[@]}"; then
            echo ""
            echo "Push failed. Use 'sb inject --force' to overwrite,"
            echo "or 'sb extract' to pull VM changes first."
            exit 1
        fi
    fi

    if [ ${#SB_WORKTREES[@]} -gt 0 ]; then
        echo "Updating worktrees in VM..."
        local wt_script="cd $VM_REPO_PATH"
        for wt in "${SB_WORKTREES[@]}"; do
            wt_script+=$'\n'"if [ -d \"$wt\" ] && git -C \"$wt\" rev-parse --git-dir &>/dev/null; then"
            wt_script+=$'\n'"    git -C \"$wt\" reset --hard \"refs/heads/$wt\""
            wt_script+=$'\n'"else"
            wt_script+=$'\n'"    git worktree add \"$wt\" \"$wt\" 2>/dev/null || true"
            wt_script+=$'\n'"fi"
        done
        sb_ssh "$ip" bash <<< "$wt_script"
    fi

    echo ""
    echo "Pushed: ${branches[*]}"
}

cmd_extract() {
    local branches=("${SB_BRANCHES[@]}")

    local ip
    ip="$(vm_ip)" || {
        echo "Error: VM is not running."
        exit 1
    }

    setup_git_remote "$ip"

    echo "Fetching from VM..."
    git -C "$PROJECT_ROOT" fetch vm "${branches[@]}"

    local has_changes=false
    for branch in "${branches[@]}"; do
        local log
        log="$(git -C "$PROJECT_ROOT" log --oneline "$branch..vm/$branch" 2>/dev/null || true)"
        echo "$branch:"
        if [ -n "$log" ]; then
            echo "$log"
            has_changes=true
        else
            echo "  (no changes)"
        fi
        echo ""
    done

    if [ "$has_changes" = false ]; then
        echo "No changes in VM."
        return
    fi

    echo "To apply: sb apply"
}

cmd_apply() {
    local branches=("${SB_BRANCHES[@]}")

    local ip
    ip="$(vm_ip)" || {
        echo "Error: VM is not running."
        exit 1
    }

    setup_git_remote "$ip"

    echo "Fetching from VM..."
    git -C "$PROJECT_ROOT" fetch vm "${branches[@]}"

    cd "$PROJECT_ROOT"

    if [ -d "$PROJECT_ROOT/.jj" ]; then
        apply_jj "${branches[@]}"
    else
        apply_git "${branches[@]}"
    fi
}

apply_jj() {
    local branches=("$@")
    local jj_config='revset-aliases."immutable_heads()"="builtin_immutable_heads() ~ untracked_remote_bookmarks(remote=vm)"'

    jj git import

    local applied=false
    for branch in "${branches[@]}"; do
        local incoming="::${branch}@vm ~ ::${branch}"

        if [ -z "$(jj log -r "$incoming" --no-graph -T 'change_id' 2>/dev/null)" ]; then
            continue
        fi

        echo "Rebasing and signing $branch..."

        local tip
        tip=$(jj log -r "heads($incoming)" --no-graph --limit 1 -T 'change_id.shortest(8)')

        local change_ids=()
        while IFS= read -r cid; do
            [ -z "$cid" ] && continue
            change_ids+=("$cid")
        done < <(jj log -r "$incoming" --no-graph -T 'change_id.shortest(8) ++ "\n"')

        if ! jj rebase --config "$jj_config" -s "roots($incoming)" -d "$branch"; then
            echo "Error: rebase failed for $branch."
            exit 1
        fi

        for cid in "${change_ids[@]}"; do
            jj log -r "$cid" --no-graph -T description | \
                jj describe --stdin --config "$jj_config" -r "$cid"
        done

        jj bookmark set "$branch" -r "$tip"
        applied=true
    done

    if [ "$applied" = true ]; then
        echo ""
        echo "Bookmarks updated. Review with 'jj log'."
    else
        echo "No changes to apply."
    fi
}

apply_git() {
    local branches=("$@")

    local applied=false
    for branch in "${branches[@]}"; do
        local log
        log="$(git log --oneline "$branch..vm/$branch" 2>/dev/null || true)"
        if [ -z "$log" ]; then
            continue
        fi

        echo "Cherry-picking and signing $branch..."

        local is_worktree=false
        for wt in "${SB_WORKTREES[@]+"${SB_WORKTREES[@]}"}"; do
            if [ "$wt" = "$branch" ]; then
                is_worktree=true
                break
            fi
        done

        if [ "$is_worktree" = true ]; then
            if ! git -C "$branch" cherry-pick "${branch}..vm/${branch}"; then
                echo "Error: cherry-pick failed for $branch."
                echo "Resolve conflicts in the $branch worktree, then: git cherry-pick --continue"
                exit 1
            fi
        else
            git checkout "$branch"
            if ! git cherry-pick "${branch}..vm/${branch}"; then
                echo "Error: cherry-pick failed for $branch."
                echo "Resolve conflicts, then: git cherry-pick --continue"
                exit 1
            fi
        fi
        applied=true
    done

    if [ "$applied" = true ]; then
        echo ""
        echo "Branches updated. Review with 'git log'."
    else
        echo "No changes to apply."
    fi
}

cmd_help() {
    cat <<EOF
Usage: sb <command> [args]

Manage sandbox VMs for isolated development with coding agents.

Commands:
  create       Create and provision a sandbox VM [--use-registry]
  ssh [cmd]    SSH into the VM; with args, runs command non-interactively
  scp          Copy files to/from VM (use vm: prefix for VM paths)
  start        Start a stopped VM
  stop         Stop the VM (preserves state)
  destroy      Stop and delete the VM
  reset        Destroy, recreate, and re-inject code [--use-registry]
  restart      Stop and restart the VM
  status       Show VM state and IP
  ip           Print VM IP address
  list         List all Tart VMs
  inject       Push branches from host into VM [--force] [branch...]
  extract      Fetch and show VM changes
  apply        Fetch and apply VM changes to host repository
  pull         Pull latest base image from registry
  help         Show this help

Configuration (.sandboxrc in project root, or sandboxrc under \$SB_CONFIG_PATH):
  SB_BRANCHES      Branches to sync (default: main)
  SB_WORKTREES     Branches to check out as worktrees (default: none)
  SB_PORTS         Port forwards as host:vm pairs (default: none)
  SB_SOCKETS       Socket forwards as host:vm pairs (default: clipper)
  SB_SSH_EXEC      Command to exec on SSH (default: cd into repo + login shell)
  SB_REPO_SUBDIR   VM home subdirectory holding the repo (default: code)
  SB_VM_CPU        CPU cores (default: 4)
  SB_VM_MEMORY     Memory in MB (default: 8192)
  SB_VM_IMAGE      Base OCI image
  sb_provision()   Custom provisioning function; receives VM IP as \$1

Environment:
  SB_CONFIG_PATH   Colon-separated directories searched for sandboxrc
                   mirroring the project path relative to \$HOME (e.g.
                   for ~/foo/bar, \$dir/foo/bar/sandboxrc). Used when
                   the repo has no local .sandboxrc.

VM: $VM_NAME
Project: $PROJECT_ROOT
EOF
}

# --- Dispatch ---

USE_REGISTRY=false
args=()
for arg in "$@"; do
    case "$arg" in
        --use-registry) USE_REGISTRY=true ;;
        *) args+=("$arg") ;;
    esac
done
set -- "${args[@]+"${args[@]}"}"

case "${1:-}" in
    create)
        cmd_create
        ;;
    ssh)
        shift
        cmd_ssh "$@"
        ;;
    scp)
        shift
        cmd_scp "$@"
        ;;
    start)
        cmd_start
        ;;
    stop)
        cmd_stop
        ;;
    destroy)
        cmd_destroy
        ;;
    reset)
        cmd_reset
        ;;
    restart)
        cmd_restart
        ;;
    status)
        cmd_status
        ;;
    ip)
        cmd_ip
        ;;
    list)
        cmd_list
        ;;
    inject)
        shift
        cmd_inject "$@"
        ;;
    extract)
        cmd_extract
        ;;
    apply)
        cmd_apply
        ;;
    pull)
        cmd_pull
        ;;
    help|--help|-h)
        cmd_help
        ;;
    "")
        if vm_exists; then
            cmd_ssh
        else
            echo "No VM '$VM_NAME' found. Run 'sb create' to get started."
            exit 1
        fi
        ;;
    *)
        echo "Unknown command: $1"
        echo "Run 'sb help' for usage."
        exit 1
        ;;
esac
