#!/usr/bin/env bash
# nvim-open: kitty open-actions handler for file:// hyperlinks.
#
# Usage: nvim-open <url>
#
# Routes a click on a file:// URL to nvim:
#
# - If the click came from a tmux pane that's running ssh, forwards over ssh
#   to the same script on the remote machine. The recursion bottoms out there,
#   since on the remote there's no kitty/tmux to redirect into.
#
# - Otherwise, finds the nvim running in a sibling tmux pane (same algorithm
#   as shannon-find-nvim.sh) and dispatches via shannon's private.open RPC.
#
# The same script is intended to be deployed on both Mac and any SSH targets
# (it ships in shannon's pack, which lives on the nvim runtimepath of every
# machine you use). All routing decisions are local; no per-VM config required.
#
# Logging is opt-in: set NVIM_OPEN_DEBUG=1 to capture trace output to
# ${XDG_STATE_HOME:-$HOME/.local/state}/nvim-open/log.

set -u

# kitty open-actions invoke us with a minimal PATH (launchd-style on macOS),
# so neither nvim nor tmux is found. Prepend common Mac tool locations.
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

if [ -n "${NVIM_OPEN_DEBUG:-}" ]; then
	LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/nvim-open"
	LOG="$LOG_DIR/log"
	mkdir -p "$LOG_DIR" 2>/dev/null || true
	log() { printf '[%s %d] %s\n' "$(date '+%H:%M:%S')" "$$" "$*" >>"$LOG"; }
else
	LOG=/dev/null
	log() { :; }
fi

log "click: argv=$*"
log "env: SSH_CONNECTION='${SSH_CONNECTION:-}' KITTY_WINDOW_ID='${KITTY_WINDOW_ID:-}' TMUX='${TMUX:-}'"

url="${1:?url required}"

# --- Parse file://[host]/path[#fragment] -----------------------------------

case "$url" in
	file://*) ;;
	*) log "→ not a file:// URL, ignoring"; exit 1 ;;
esac

rest="${url#file://}"
rest="/${rest#*/}"  # drop host component, keep leading slash
url_path_encoded="${rest%%#*}"
url_fragment=""
case "$rest" in
	*\#*) url_fragment="${rest#*#}" ;;
esac

# Percent-decode path. Bash's `printf %b` consumes \xNN escapes, so we map
# percent-encoding into that form. Safe-enough for typical paths; weird Unicode
# might warrant a Python fallback later. Keep the encoded form around so we
# can forward it verbatim over ssh without lossy round-tripping.
url_path=$(printf '%b' "${url_path_encoded//%/\\x}")

# Fragment is "line" or "line:col"; we use line, defaulting to 1.
line="${url_fragment%%:*}"
case "$line" in ''|*[!0-9]*) line=1 ;; esac

log "parsed: url_path='$url_path' line=$line"

# --- Detect ssh in the active tmux pane ------------------------------------

# Skip detection when *we* were invoked over ssh: that means we're already on
# the remote side of a previous dispatch, and any tmux+ssh found here would
# (incorrectly) re-forward elsewhere.
ssh_target=""
if [ -z "${SSH_CONNECTION:-}" ]; then
	pane_tty=$(tmux display-message -p '#{pane_tty}' 2>/dev/null) || pane_tty=""
	log "pane_tty='$pane_tty'"

	if [ -n "$pane_tty" ]; then
		tty_arg="${pane_tty#/dev/}"

		# Look for ssh in the pane's processes; extract destination from argv.
		# Skip flag args, including those that take a value (-p PORT, -i KEY,
		# -o opt=val, -J jumphost, -l user, -F config, -L/-R/-D/-W forwards,
		# -B/-b/-c/-E/-e/-I/-m/-O/-Q/-S/-w). The first non-flag positional is
		# the destination.
		ssh_target=$(ps -t "$tty_arg" -o args= 2>/dev/null | awk '
			function dest(    n, i, tok) {
				n = NF
				i = 2
				while (i <= n) {
					tok = $i
					if (tok ~ /^-[bcDEeFIiJLlmOopQRSWw]./) { i++; continue }
					if (tok ~ /^-[bcDEeFIiJLlmOopQRSWw]$/) { i += 2; continue }
					if (tok ~ /^-/) { i++; continue }
					return tok
				}
				return ""
			}
			$1 ~ /(^|\/)ssh$/ {
				d = dest()
				if (d != "") { print d; exit }
			}
		')
		log "ssh_target='$ssh_target'"
	fi
fi

# --- Remote dispatch -------------------------------------------------------

if [ -n "$ssh_target" ]; then
	# Re-emit URL with empty host so the remote skips its own detection and
	# goes straight to local routing. The remote's nvim-open lives at the same
	# pack path, since shannon is deployed identically.
	#
	# Use the still-encoded path so a literal `%` in the original path (which
	# arrived here as `%25`) is not silently corrupted: rebuilding from the
	# decoded `url_path` would ship `file:///foo%off` to the remote, where
	# `%of` would then be mis-parsed as a hex escape.
	remote_url="file://${url_path_encoded}"
	[ -n "$url_fragment" ] && remote_url="${remote_url}#${url_fragment}"
	log "→ forwarded to $ssh_target via ssh"
	exec ssh "$ssh_target" "\$HOME/.config/nvim/pack/bundle/opt/shannon/bin/nvim-open" "$remote_url"
fi

# --- Local routing: find sibling-pane nvim ---------------------------------

# Bail early if the path doesn't exist locally — better than dispatching to
# nvim and creating a stray empty buffer.
if [ ! -e "$url_path" ]; then
	log "→ path does not exist locally: $url_path"
	exit 1
fi

# Skip nvim for binary files. `file --mime-encoding` returns one of utf-8,
# us-ascii, iso-8859-1, etc. for textual content, or `binary` for everything
# else (images, archives, executables, compiled object files, etc.). On macOS
# we hand off to `open`, which routes to the default app (Preview for images,
# Finder for archives, etc.) — same behavior as a Finder double-click.
#
# When invoked over ssh on a remote, there's no good "open on remote" story
# (no display), so we just log and exit; the user can scp the file manually.
mime_encoding=$(file --brief --mime-encoding "$url_path" 2>/dev/null) || mime_encoding=""
if [ "$mime_encoding" = "binary" ]; then
	if [ -z "${SSH_CONNECTION:-}" ] && command -v open >/dev/null 2>&1; then
		log "→ binary, handing to 'open': $url_path"
		exec open "$url_path"
	fi
	log "→ binary, no graceful handler available: $url_path"
	exit 1
fi

# Discover the sibling-pane nvim's socket. find-nvim-socket is a sibling
# script in this same bin/ directory, also used (via a wrapper) by the
# wincent-claude-plugins shannon skill.
script_dir=$(cd "$(dirname "$0")" && pwd)
sock=$("$script_dir/find-nvim-socket" 2>>"$LOG") || {
	log "→ nvim discovery failed (see preceding stderr lines)"
	exit 1
}
log "sock='$sock'"

# --- Dispatch via shannon's RPC --------------------------------------------

# Use shannon's private.open helper. Path is wrapped in a Lua long-bracket
# string literal, which has no escape rules: only the literal terminator
# `]==]` would need escaping, and that sequence cannot appear in a POSIX
# filesystem path. This sidesteps the layered shell + Vimscript + Lua
# quoting that would otherwise be required for paths containing quotes
# or backslashes.
expr="luaeval(\"require('wincent.shannon.private.open')([==[${url_path}]==], ${line})\")"

if nvim --server "$sock" --remote-expr "$expr" >/dev/null 2>>"$LOG"; then
	log "→ opened in nvim (sock=$sock, line=$line)"
	exit 0
else
	log "→ RPC failed (sock=$sock)"
	exit 1
fi
