# Top-level .gitignore for this repo.
#
# This file contains ignore entries for:
#
# - Items in the repo root directory.
# - Plaintext versions of encrypted files (this list gets appended to by the
#   `wage` tool).
#
# For all other ignored items, prefer recording them in directory-local
# .gitignore files.

# Cache for local clones of dependency Git repos (see
# `bin/update-dependencies`).
/.cache

# Git worktrees (ie. `git worktree add media media`).
/media

# Build artifacts.
/tsconfig.tsbuildinfo

# Third-party.
/node_modules

