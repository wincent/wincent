# Tinted8 {{scheme.name}}
# Scheme author: {{scheme.author}}
# Template author: Tinted Theming: (https://github.com/tinted-theming)

# default statusbar colors
set-option -g status-style "fg=#{{ui.global.foreground.normal.hex}},bg=#{{ui.global.background.normal.hex}}"

# default window title colors
set-window-option -g window-status-style "fg=#{{ui.global.foreground.normal.hex}},bg=#{{ui.global.background.normal.hex}}"

# active window title colors
set-window-option -g window-status-current-style "fg=#{{palette.yellow.normal.hex}},bg=#{{ui.global.background.normal.hex}}"

# pane border
set-option -g pane-border-style "fg=#{{ui.border.hex}}"
set-option -g pane-active-border-style "fg=#{{ui.accent.hex}}"

# message text
set-option -g message-style "fg=#{{ui.global.foreground.light.hex}},bg=#{{ui.global.background.light.hex}}"

# pane number display
set-option -g display-panes-active-colour "#{{ui.accent.hex}}"
set-option -g display-panes-colour "#{{ui.global.background.light.hex}}"

# clock
set-window-option -g clock-mode-colour "#{{palette.blue.normal.hex}}"

# copy mode highlight
set-window-option -g mode-style "fg=#{{ui.global.foreground.dark.hex}},bg=#{{ui.selection.background.hex}}"

# bell
set-window-option -g window-status-bell-style "fg=#{{ui.global.background.normal.hex}},bg=#{{palette.red.normal.hex}}"

# style for window titles with activity
set-window-option -g window-status-activity-style "fg=#{{ui.global.foreground.normal.hex}},bg=#{{ui.global.background.normal.hex}}"

# style for command messages
set-option -g message-command-style "fg=#{{ui.global.foreground.light.hex}},bg=#{{ui.global.background.light.hex}}"

# Optional active/inactive pane state
if-shell '[ "$TINTED_TMUX_OPTION_ACTIVE" = "1" ]' {
  set-window-option -g window-active-style "fg=#{{ui.global.foreground.normal.hex}},bg=#{{ui.global.background.normal.hex}}"
  set-window-option -g window-style "fg=#{{ui.global.foreground.normal.hex}},bg=#{{ui.global.background.dark.hex}}"
}

# Optional statusbar
if-shell '[ "$TINTED_TMUX_OPTION_STATUSBAR" = "1" ]' {
  set-option -g status "on"
  set-option -g status-justify "left"
  set-option -g status-left "#[fg=#{{ui.global.foreground.normal.hex}},bg=#{{ui.selection.background.hex}}] #S #[fg=#{{ui.selection.background.hex}},bg=#{{ui.global.background.normal.hex}},nobold,noitalics,nounderscore]"
  set-option -g status-left-length "80"
  set-option -g status-left-style none
  set-option -g status-right "#[fg=#{{ui.global.background.light.hex}},bg=#{{ui.global.background.normal.hex}} nobold, nounderscore, noitalics]#[fg=#{{ui.global.foreground.dark.hex}},bg=#{{ui.global.background.light.hex}}] %Y-%m-%d  %H:%M #[fg=#{{ui.global.foreground.normal.hex}},bg=#{{ui.global.background.light.hex}},nobold,noitalics,nounderscore]#[fg=#{{ui.global.background.normal.hex}},bg=#{{ui.global.foreground.normal.hex}}] #h "
  set-option -g status-right-length "80"
  set-option -g status-right-style none
  set-window-option -g window-status-current-format "#[fg=#{{ui.global.background.normal.hex}},bg=#{{palette.yellow.normal.hex}},nobold,noitalics,nounderscore]#[fg=#{{ui.global.background.light.hex}},bg=#{{palette.yellow.normal.hex}}] #I #[fg=#{{ui.global.background.light.hex}},bg=#{{palette.yellow.normal.hex}},bold] #W#{?window_zoomed_flag,*Z,} #[fg=#{{palette.yellow.normal.hex}},bg=#{{ui.global.background.normal.hex}},nobold,noitalics,nounderscore]"
  set-window-option -g window-status-format "#[fg=#{{ui.global.background.normal.hex}},bg=#{{ui.global.background.light.hex}},noitalics]#[fg=#{{ui.global.foreground.light.hex}},bg=#{{ui.global.background.light.hex}}] #I #[fg=#{{ui.global.foreground.light.hex}},bg=#{{ui.global.background.light.hex}}] #W#{?window_zoomed_flag,*Z,} #[fg=#{{ui.global.background.light.hex}},bg=#{{ui.global.background.normal.hex}},noitalics]"
  set-window-option -g window-status-separator ""
}

