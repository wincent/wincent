# Scheme name: Alucard
# Scheme system: base24
# Scheme author: clach04 (https://github.com/clach04)
# Template author: https://github.com/tinted-theming/tinted-kermit-terminal

# Foreground color
foreground         0x1f1f1f
foreground_bold    0x1f1f1f

# Cursor color
cursor             0x1f1f1f
