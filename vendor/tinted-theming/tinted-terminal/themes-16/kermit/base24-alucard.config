color3 0x846e15 # base0A - Yellow
color4 0x644ac9 # base0D - Blue
color5 0xa3144d # base0E - Magenta
color6 0x036a96 # base0C - Cyan
color7 0x1f1f1f # base05 - White
color8 0x6c664b # base03 - Bright Black
color9 0xd74c3d # base12 - Bright Red
color10 0x198d0c # base14 - Bright Green
color11 0x9e841a # base13 - Bright Yellow
color12 0x7862d0 # base16 - Bright Blue
color13 0xbf185a # base17 - Bright Magenta
