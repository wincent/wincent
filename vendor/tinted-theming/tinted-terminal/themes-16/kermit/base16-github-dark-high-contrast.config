# Scheme name: Github Dark High Contrast
# Scheme system: base16
# Scheme author: Tinted Theming (https://github.com/tinted-theming)
# Template author: https://github.com/tinted-theming/tinted-kermit-terminal

# Foreground color
foreground         0xf0f3f6
foreground_bold    0xffffff

# Cursor color
cursor             0xf0f3f6
cursor_foreground  0x0a0c10

# Background color
background         0x0a0c10

color0 0x0a0c10 # base00 - Black
color1 0xffb757 # base08 - Red
color2 0xaddcff # base0B - Green
color3 0xe09b13 # base0A - Yellow
color4 0xdbb7ff # base0D - Blue
color5 0xff9492 # base0E - Magenta
color6 0x72f088 # base0C - Cyan
color7 0xf0f3f6 # base05 - White
color8 0x9ea7b3 # base03 - Bright Black
color9 0xffb757 # base08 - Bright Red
color10 0xaddcff # base0B - Bright Green
color11 0xe09b13 # base0A - Bright Yellow
color12 0xdbb7ff # base0D - Bright Blue
color13 0xff9492 # base0E - Bright Magenta
color14 0x72f088 # base0C - Bright Cyan
color15 0xffffff # base07 - Bright White
