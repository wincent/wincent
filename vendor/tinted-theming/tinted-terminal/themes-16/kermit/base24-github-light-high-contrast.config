# Scheme name: Github Light High Contrast
# Scheme system: base24
# Scheme author: Tinted Theming (https://github.com/tinted-theming)
# Template author: https://github.com/tinted-theming/tinted-kermit-terminal

# Foreground color
foreground         0x343b43
foreground_bold    0x20252c

# Cursor color
cursor             0x343b43
cursor_foreground  0xffffff

# Background color
background         0xffffff

color0 0xffffff # base00 - Black
color1 0x702c00 # base08 - Red
color2 0x032563 # base0B - Green
color3 0x956400 # base0A - Yellow
color4 0x622cbc # base0D - Blue
color5 0xa0111f # base0E - Magenta
color6 0x024c1a # base0C - Cyan
color7 0x343b43 # base05 - White
color8 0x88929d # base03 - Bright Black
color9 0xee5a5d # base12 - Bright Red
color10 0x26a148 # base14 - Bright Green
color11 0xb58407 # base13 - Bright Yellow
color12 0x368cf9 # base16 - Bright Blue
color13 0xa371f7 # base17 - Bright Magenta
color14 0x49bcb7 # base15 - Bright Cyan
color15 0x0e1116 # base07 - Bright White
