# Scheme name: Github Light Colorblind
# Scheme system: base16
# Scheme author: Tinted Theming (https://github.com/tinted-theming)
# Template author: https://github.com/tinted-theming/tinted-kermit-terminal

# Foreground color
foreground         0x424a53
foreground_bold    0x32383f

# Cursor color
cursor             0x424a53
cursor_foreground  0xffffff

# Background color
background         0xffffff

color0 0xffffff # base00 - Black
color1 0x8a4600 # base08 - Red
color2 0x0a3069 # base0B - Green
color3 0xbf8700 # base0A - Yellow
color4 0x8250df # base0D - Blue
color5 0xb35900 # base0E - Magenta
color6 0x0550ae # base0C - Cyan
color7 0x424a53 # base05 - White
color8 0x8c959f # base03 - Bright Black
color9 0x8a4600 # base08 - Bright Red
color10 0x0a3069 # base0B - Bright Green
color11 0xbf8700 # base0A - Bright Yellow
color12 0x8250df # base0D - Bright Blue
color13 0xb35900 # base0E - Bright Magenta
color14 0x0550ae # base0C - Bright Cyan
color15 0x24292f # base07 - Bright White
