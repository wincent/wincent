# Shades Of Purple theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #1e1d40
Red         = #d90429
Green       = #3ad900
Yellow      = #6871ff
Blue        = #6943ff
Magenta     = #ff2b70
Cyan        = #00c5c7
White       = #afafaf
BoldBlack   = #7f7f7f
BoldRed     = #f9291b
BoldGreen   = #42d425
BoldYellow  = #f1d000
BoldBlue    = #6871ff
BoldMagenta = #ff76ff
BoldCyan    = #79e7fa
BoldWhite   = #feffff

# Background & foreground colors
BackgroundColour = #1e1d40
ForegroundColour = #afafaf
CursorColour     = #afafaf
