# Github Dark theme for Mintty
# Scheme Author: Tinted Theming (https://github.com/tinted-theming)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #0d1117
Red         = #ffa657
Green       = #a5d6ff
Yellow      = #bb8009
Blue        = #d2a8ff
Magenta     = #ff7b72
Cyan        = #7ee787
White       = #c9d1d9
BoldBlack   = #6e7681
BoldRed     = #ff7b72
BoldGreen   = #3fb950
BoldYellow  = #d29922
BoldBlue    = #58a6ff
BoldMagenta = #bc8cff
BoldCyan    = #33b3ae
BoldWhite   = #ffffff

# Background & foreground colors
BackgroundColour = #0d1117
ForegroundColour = #c9d1d9
CursorColour     = #c9d1d9
