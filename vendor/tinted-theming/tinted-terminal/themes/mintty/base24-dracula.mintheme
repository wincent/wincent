# Dracula theme for Mintty
# Scheme Author: clach04 (https://github.com/clach04)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #282a36
Red         = #ff5555
Green       = #50fa7b
Yellow      = #f1fa8c
Blue        = #bd93f9
Magenta     = #ff79c6
Cyan        = #8be9fd
White       = #f8f8f2
BoldBlack   = #6272a4
BoldRed     = #ff6e6e
BoldGreen   = #69ff94
BoldYellow  = #ffffa5
BoldBlue    = #d6acff
BoldMagenta = #ff92df
BoldCyan    = #a4ffff
BoldWhite   = #ffffff

# Background & foreground colors
BackgroundColour = #282a36
ForegroundColour = #f8f8f2
CursorColour     = #f8f8f2
