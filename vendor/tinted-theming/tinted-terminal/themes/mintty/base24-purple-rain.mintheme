# Purple Rain theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #20084a
Red         = #ff260d
Green       = #9ae204
Yellow      = #00a5ff
Blue        = #00a1f9
Magenta     = #805bb5
Cyan        = #00ddef
White       = #d3d4d4
BoldBlack   = #7f7f7f
BoldRed     = #ff4250
BoldGreen   = #b8e36d
BoldYellow  = #ffd852
BoldBlue    = #00a5ff
BoldMagenta = #ab7aef
BoldCyan    = #74fcf3
BoldWhite   = #feffff

# Background & foreground colors
BackgroundColour = #20084a
ForegroundColour = #d3d4d4
CursorColour     = #d3d4d4
