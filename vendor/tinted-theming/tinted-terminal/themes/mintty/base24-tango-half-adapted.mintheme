# Tango Half Adapted theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #feffff
Red         = #ff0000
Green       = #4cc300
Yellow      = #e2bf00
Blue        = #008df5
Magenta     = #a86bb2
Cyan        = #00bdc3
White       = #4f4f4f
BoldBlack   = #cccccc
BoldRed     = #ff0012
BoldGreen   = #8af600
BoldYellow  = #ffeb00
BoldBlue    = #75beff
BoldMagenta = #d798d0
BoldCyan    = #00f6fa
BoldWhite   = #000000

# Background & foreground colors
BackgroundColour = #feffff
ForegroundColour = #4f4f4f
CursorColour     = #4f4f4f
