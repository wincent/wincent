# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #fbf1c7
Red         = #cc241d
Green       = #98971a
Yellow      = #d79921
Blue        = #458588
Magenta     = #b16286
Cyan        = #689d6a
White       = #3c3836
BoldBlack   = #bdae93
BoldRed     = #9d0006
BoldGreen   = #79740e
BoldYellow  = #b57614
BoldBlue    = #076678
BoldMagenta = #8f3f71
BoldCyan    = #427b58
BoldWhite   = #1d2021

# Background & foreground colors
BackgroundColour = #fbf1c7
ForegroundColour = #3c3836
CursorColour     = #3c3836
