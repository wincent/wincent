# Twilight theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #141414
Red         = #c06c43
Green       = #afb979
Yellow      = #5a5d61
Blue        = #444649
Magenta     = #b4be7b
Cyan        = #778284
White       = #c8c8a7
BoldBlack   = #5c5c51
BoldRed     = #dd7c4c
BoldGreen   = #cbd88c
BoldYellow  = #e1c47d
BoldBlue    = #5a5d61
BoldMagenta = #d0db8e
BoldCyan    = #8a989a
BoldWhite   = #feffd3

# Background & foreground colors
BackgroundColour = #141414
ForegroundColour = #c8c8a7
CursorColour     = #c8c8a7
