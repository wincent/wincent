# Tomorrow Night theme for Mintty
# Scheme Author: Cody Buell (https://github.com/codybuell)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #1d1f21
Red         = #cc6666
Green       = #b5bd68
Yellow      = #f0c674
Blue        = #81a2be
Magenta     = #b294bb
Cyan        = #8abeb7
White       = #c5c8c6
BoldBlack   = #969896
BoldRed     = #e74c3c
BoldGreen   = #b8d4b3
BoldYellow  = #f7dc6f
BoldBlue    = #85c1e9
BoldMagenta = #d7a3ca
BoldCyan    = #95d3ce
BoldWhite   = #ffffff

# Background & foreground colors
BackgroundColour = #1d1f21
ForegroundColour = #c5c8c6
CursorColour     = #c5c8c6
