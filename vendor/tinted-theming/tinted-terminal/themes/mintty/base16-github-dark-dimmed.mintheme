# Github Dark Dimmed theme for Mintty
# Scheme Author: Tinted Theming (https://github.com/tinted-theming)
# Scheme System: base16
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #22272e
Red         = #f69d50
Green       = #96d0ff
Yellow      = #ae7c14
Blue        = #dcbdfb
Magenta     = #f47067
Cyan        = #8ddb8c
White       = #adbac7
BoldBlack   = #636e7b
BoldRed     = #f69d50
BoldGreen   = #96d0ff
BoldYellow  = #ae7c14
BoldBlue    = #dcbdfb
BoldMagenta = #f47067
BoldCyan    = #8ddb8c
BoldWhite   = #ffffff

# Background & foreground colors
BackgroundColour = #22272e
ForegroundColour = #adbac7
CursorColour     = #adbac7
