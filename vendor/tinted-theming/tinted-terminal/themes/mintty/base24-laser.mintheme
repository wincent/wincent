# Laser theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #030d18
Red         = #ff8272
Green       = #b4fa72
Yellow      = #f92883
Blue        = #fed300
Magenta     = #ff8ffd
Cyan        = #d0d1fe
White       = #d8d8d8
BoldBlack   = #a6a6a6
BoldRed     = #ffc4bd
BoldGreen   = #d6fcb9
BoldYellow  = #fefdd5
BoldBlue    = #f92883
BoldMagenta = #ffb1fe
BoldCyan    = #e5e6fe
BoldWhite   = #feffff

# Background & foreground colors
BackgroundColour = #030d18
ForegroundColour = #d8d8d8
CursorColour     = #d8d8d8
