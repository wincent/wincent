# Ayu Mirage theme for Mintty
# Scheme Author: Tinted Theming (https://github.com/tinted-theming), Ayu Theme (https://github.com/ayu-theme)
# Scheme System: base16
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #1f2430
Red         = #f28779
Green       = #d5ff80
Yellow      = #ffd173
Blue        = #73d0ff
Magenta     = #d4bfff
Cyan        = #95e6cb
White       = #cccac2
BoldBlack   = #4a5059
BoldRed     = #f28779
BoldGreen   = #d5ff80
BoldYellow  = #ffd173
BoldBlue    = #73d0ff
BoldMagenta = #d4bfff
BoldCyan    = #95e6cb
BoldWhite   = #f3f4f5

# Background & foreground colors
BackgroundColour = #1f2430
ForegroundColour = #cccac2
CursorColour     = #cccac2
