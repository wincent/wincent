# Operator Mono Dark theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #191919
Red         = #ca372d
Green       = #4d7b3a
Yellow      = #89d3f6
Blue        = #4387cf
Magenta     = #b86cb4
Cyan        = #72d4c6
White       = #c0c4c0
BoldBlack   = #a6a8a6
BoldRed     = #c37d62
BoldGreen   = #83d0a2
BoldYellow  = #fdfdc5
BoldBlue    = #89d3f6
BoldMagenta = #fe2c79
BoldCyan    = #82e9da
BoldWhite   = #fdfdf6

# Background & foreground colors
BackgroundColour = #191919
ForegroundColour = #c0c4c0
CursorColour     = #c0c4c0
