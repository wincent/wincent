# Terminal Basic theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #ffffff
Red         = #990000
Green       = #00a600
Yellow      = #0000ff
Blue        = #0000b2
Magenta     = #b200b2
Cyan        = #00a6b2
White       = #a8a8a8
BoldBlack   = #7c7c7c
BoldRed     = #e50000
BoldGreen   = #00d900
BoldYellow  = #e5e500
BoldBlue    = #0000ff
BoldMagenta = #e500e5
BoldCyan    = #00e5e5
BoldWhite   = #e5e5e5

# Background & foreground colors
BackgroundColour = #ffffff
ForegroundColour = #a8a8a8
CursorColour     = #a8a8a8
