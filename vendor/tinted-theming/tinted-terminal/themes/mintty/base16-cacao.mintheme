White       = #e8d6c4
BoldBlack   = #766052
BoldRed     = #e0705c
BoldGreen   = #9ac97a
BoldYellow  = #e8a84a
BoldBlue    = #a89ad0
BoldMagenta = #ce8ab0
BoldCyan    = #74c8b0
BoldWhite   = #f4e6d6

# Background & foreground colors
BackgroundColour = #160f0c
ForegroundColour = #e8d6c4
