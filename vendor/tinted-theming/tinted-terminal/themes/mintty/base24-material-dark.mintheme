# Material Dark theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #222221
Red         = #b7141e
Green       = #457b23
Yellow      = #53a4f3
Blue        = #134eb2
Magenta     = #550087
Cyan        = #0e707c
White       = #c3c3c3
BoldBlack   = #6d6d6d
BoldRed     = #e83a3f
BoldGreen   = #7aba39
BoldYellow  = #fee92e
BoldBlue    = #53a4f3
BoldMagenta = #a94dbb
BoldCyan    = #26bad1
BoldWhite   = #d8d8d8

# Background & foreground colors
BackgroundColour = #222221
ForegroundColour = #c3c3c3
CursorColour     = #c3c3c3
