Cyan        = #7fcccb
White       = #9a9fa6
BoldBlack   = #6c6d70
BoldRed     = #ec5f67
BoldGreen   = #88e985
BoldYellow  = #fdc253
BoldBlue    = #5485c0
BoldMagenta = #bf83c0
