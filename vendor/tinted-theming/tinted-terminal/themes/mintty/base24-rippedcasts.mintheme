# Rippedcasts theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #2b2b2b
Red         = #cdaf95
Green       = #a7ff60
Yellow      = #86bdc9
Blue        = #75a5b0
Magenta     = #ff73fd
Cyan        = #59647e
White       = #a8a8a8
BoldBlack   = #7c7c7c
BoldRed     = #eecbad
BoldGreen   = #bcee68
BoldYellow  = #e5e500
BoldBlue    = #86bdc9
BoldMagenta = #e500e5
BoldCyan    = #8c9bc3
BoldWhite   = #e5e5e5

# Background & foreground colors
BackgroundColour = #2b2b2b
ForegroundColour = #a8a8a8
CursorColour     = #a8a8a8
