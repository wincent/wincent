# Obsidian theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #273032
Red         = #a50001
Green       = #00bb00
Yellow      = #a0d6ff
Blue        = #399bda
Magenta     = #bb00bb
Cyan        = #00bbbb
White       = #a1a1a1
BoldBlack   = #6e6e6e
BoldRed     = #ff0003
BoldGreen   = #92c763
BoldYellow  = #fef773
BoldBlue    = #a0d6ff
BoldMagenta = #ff55ff
BoldCyan    = #55ffff
BoldWhite   = #ffffff

# Background & foreground colors
BackgroundColour = #273032
ForegroundColour = #a1a1a1
CursorColour     = #a1a1a1
