Yellow      = #39a7a2
Blue        = #8ed0ce
Magenta     = #5e468c
Cyan        = #31658c
White       = #b8b1a9
BoldBlack   = #666361
BoldRed     = #fb3d66
BoldGreen   = #6bb48d
BoldYellow  = #2fc859
BoldBlue    = #39a7a2
BoldMagenta = #7e62b3
BoldCyan    = #6096bf
BoldWhite   = #e2d8cd

# Background & foreground colors
BackgroundColour = #051519
ForegroundColour = #b8b1a9
CursorColour     = #b8b1a9
