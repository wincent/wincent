# Mathias theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #000000
Red         = #e52222
Green       = #a6e32d
Yellow      = #5555ff
Blue        = #c48dff
Magenta     = #fa2573
Cyan        = #67d9f0
White       = #cacaca
BoldBlack   = #7c7c7c
BoldRed     = #ff5555
BoldGreen   = #55ff55
BoldYellow  = #ffff55
BoldBlue    = #5555ff
BoldMagenta = #ff55ff
BoldCyan    = #55ffff
BoldWhite   = #ffffff

# Background & foreground colors
BackgroundColour = #000000
ForegroundColour = #cacaca
CursorColour     = #cacaca
