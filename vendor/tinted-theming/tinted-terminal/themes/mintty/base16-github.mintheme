# Github theme for Mintty
# Scheme Author: Tinted Theming (https://github.com/tinted-theming)
# Scheme System: base16
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #ffffff
Red         = #953800
Green       = #0a3069
Yellow      = #bf8700
Blue        = #8250df
Magenta     = #cf222e
Cyan        = #116329
White       = #424a53
BoldBlack   = #8c959f
BoldRed     = #953800
BoldGreen   = #0a3069
BoldYellow  = #bf8700
BoldBlue    = #8250df
BoldMagenta = #cf222e
BoldCyan    = #116329
BoldWhite   = #1f2328

# Background & foreground colors
BackgroundColour = #ffffff
ForegroundColour = #424a53
CursorColour     = #424a53
