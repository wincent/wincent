# Cobalt2 theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #122637
Red         = #ff0000
Green       = #37dd21
Yellow      = #5555ff
Blue        = #1460d2
Magenta     = #ff005d
Cyan        = #00bbbb
White       = #a1a1a1
BoldBlack   = #6e6e6e
BoldRed     = #f40d17
BoldGreen   = #3bcf1d
BoldYellow  = #ecc809
BoldBlue    = #5555ff
BoldMagenta = #ff55ff
BoldCyan    = #6ae3f9
BoldWhite   = #ffffff

# Background & foreground colors
BackgroundColour = #122637
ForegroundColour = #a1a1a1
CursorColour     = #a1a1a1
