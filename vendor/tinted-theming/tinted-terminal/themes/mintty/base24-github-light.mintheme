# Github Light theme for Mintty
# Scheme Author: Tinted Theming (https://github.com/tinted-theming)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #eaeef2
Red         = #fa4549
Green       = #2da44e
Yellow      = #bf8700
Blue        = #218bff
Magenta     = #a475f9
Cyan        = #339d9b
White       = #424a53
BoldBlack   = #8c959f
BoldRed     = #ff8182
BoldGreen   = #4ac26b
BoldYellow  = #d4a72c
BoldBlue    = #54aeff
BoldMagenta = #c297ff
BoldCyan    = #49bcb7
BoldWhite   = #1f2328

# Background & foreground colors
BackgroundColour = #eaeef2
ForegroundColour = #424a53
CursorColour     = #424a53
