# Borland theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #0000a4
Red         = #ff6b60
Green       = #a7ff60
Yellow      = #b5dcfe
Blue        = #96cafd
Magenta     = #ff73fd
Cyan        = #c6c4fd
White       = #d1d1d1
BoldBlack   = #989898
BoldRed     = #ffb6b0
BoldGreen   = #ceffab
BoldYellow  = #ffffcb
BoldBlue    = #b5dcfe
BoldMagenta = #ff9cfe
BoldCyan    = #dfdffe
BoldWhite   = #ffffff

# Background & foreground colors
BackgroundColour = #0000a4
ForegroundColour = #d1d1d1
CursorColour     = #d1d1d1
