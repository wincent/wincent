Magenta     = #d13a82
Cyan        = #32a198
White       = #afaea9
BoldBlack   = #686a6a
BoldRed     = #bd3612
BoldGreen   = #728903
BoldYellow  = #a57704
BoldBlue    = #2075c7
BoldMagenta = #c61b6e
BoldCyan    = #259185
BoldWhite   = #c8c5bd

# Background & foreground colors
BackgroundColour = #fcf4dc
ForegroundColour = #afaea9
CursorColour     = #afaea9
