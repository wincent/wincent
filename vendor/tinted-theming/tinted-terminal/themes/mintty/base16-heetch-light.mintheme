Cyan        = #47f9f5
White       = #5a496e
BoldBlack   = #9c92a8
BoldRed     = #f80059
BoldGreen   = #5bb66a
BoldYellow  = #bd9701
BoldBlue    = #5ba2b6
BoldMagenta = #8f6c97
BoldCyan    = #47f9f5
BoldWhite   = #190134

# Background & foreground colors
BackgroundColour = #feffff
ForegroundColour = #5a496e
CursorColour     = #5a496e
