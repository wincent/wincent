# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #1b153c
Red         = #ff0051
Green       = #00dc84
Yellow      = #6871ff
Blue        = #0271b6
Magenta     = #c930c7
Cyan        = #00c5c7
White       = #afafaf
BoldBlack   = #7f7f7f
BoldRed     = #ff6d67
BoldGreen   = #5ff967
BoldYellow  = #fefb67
BoldBlue    = #6871ff
BoldMagenta = #bc35eb
BoldCyan    = #5ffdff
BoldWhite   = #feffff

# Background & foreground colors
BackgroundColour = #1b153c
ForegroundColour = #afafaf
CursorColour     = #afafaf
