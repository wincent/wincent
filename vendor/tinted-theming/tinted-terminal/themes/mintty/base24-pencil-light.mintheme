# Pencil Light theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #f1f1f1
Red         = #c30771
Green       = #10a778
Yellow      = #20bbfc
Blue        = #008ec4
Magenta     = #523c79
Cyan        = #20a5ba
White       = #b3b3b3
BoldBlack   = #676767
BoldRed     = #fb007a
BoldGreen   = #5fd7af
BoldYellow  = #f3e430
BoldBlue    = #20bbfc
BoldMagenta = #6855de
BoldCyan    = #4fb8cc
BoldWhite   = #f1f1f1

# Background & foreground colors
BackgroundColour = #f1f1f1
ForegroundColour = #b3b3b3
CursorColour     = #b3b3b3
