# deep theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #080808
Red         = #d60005
Green       = #1cd815
Yellow      = #9fa8fe
Blue        = #5665fe
Magenta     = #af51d9
Cyan        = #4fd2d9
White       = #bcbcbc
BoldBlack   = #767676
BoldRed     = #fb0006
BoldGreen   = #21fe17
BoldYellow  = #fedc2b
BoldBlue    = #9fa8fe
BoldMagenta = #e099fe
BoldCyan    = #8cf9fe
BoldWhite   = #fffefe

# Background & foreground colors
BackgroundColour = #080808
ForegroundColour = #bcbcbc
CursorColour     = #bcbcbc
