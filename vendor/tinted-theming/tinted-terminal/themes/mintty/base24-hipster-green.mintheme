# Hipster Green theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #0f0a05
Red         = #b6204a
Green       = #00a600
Yellow      = #0000ff
Blue        = #246db2
Magenta     = #b200b2
Cyan        = #00a6b2
White       = #a8a8a8
BoldBlack   = #7c7c7c
BoldRed     = #e50000
BoldGreen   = #86a83e
BoldYellow  = #e5e500
BoldBlue    = #0000ff
BoldMagenta = #e500e5
BoldCyan    = #00e5e5
BoldWhite   = #e5e5e5

# Background & foreground colors
BackgroundColour = #0f0a05
ForegroundColour = #a8a8a8
CursorColour     = #a8a8a8
