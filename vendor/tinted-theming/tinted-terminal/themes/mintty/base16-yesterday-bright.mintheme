Magenta     = #c397d8
Cyan        = #70c0b1
White       = #dfe1e8
BoldBlack   = #a7adba
BoldRed     = #d54e53
BoldGreen   = #b9ca4a
BoldYellow  = #e7c547
BoldBlue    = #7aa6da
BoldMagenta = #c397d8
