Cyan        = #7e82cc
White       = #bbb2ad
BoldBlack   = #534a5e
BoldRed     = #c77171
BoldGreen   = #0a6b7e
BoldYellow  = #793188
BoldBlue    = #38163d
BoldMagenta = #bc93b6
BoldCyan    = #5d5f71
