# Flexoki Dark theme for Mintty
# Scheme Author: Steph Ango (https://github.com/kepano/flexoki)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #100f0f
Red         = #d14d41
Green       = #879a39
Yellow      = #d0a215
Blue        = #4385be
Magenta     = #8b7ec8
Cyan        = #3aa99f
White       = #cecdc3
BoldBlack   = #575653
BoldRed     = #af3029
BoldGreen   = #ad8301
BoldYellow  = #bc5215
BoldBlue    = #24837b
BoldMagenta = #205ea6
BoldCyan    = #66800b
BoldWhite   = #fffcf0

# Background & foreground colors
BackgroundColour = #100f0f
ForegroundColour = #cecdc3
CursorColour     = #cecdc3
