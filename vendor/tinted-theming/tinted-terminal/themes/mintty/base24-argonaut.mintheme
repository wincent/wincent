# Argonaut theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #0d0f18
Red         = #ff000f
Green       = #8ce00a
Yellow      = #0092ff
Blue        = #008df8
Magenta     = #6c43a5
Cyan        = #00d7eb
White       = #d0d0d0
BoldBlack   = #727272
BoldRed     = #ff273f
BoldGreen   = #abe05a
BoldYellow  = #ffd141
BoldBlue    = #0092ff
BoldMagenta = #9a5feb
BoldCyan    = #67ffef
BoldWhite   = #ffffff

# Background & foreground colors
BackgroundColour = #0d0f18
ForegroundColour = #d0d0d0
CursorColour     = #d0d0d0
