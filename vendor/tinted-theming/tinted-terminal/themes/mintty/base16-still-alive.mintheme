# Scheme System: base16
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #f0f0f0
Red         = #d80000
Green       = #30a860
Yellow      = #fff018
Blue        = #365eff
Magenta     = #9036ff
Cyan        = #36d3ff
White       = #4c383b
BoldBlack   = #a3a3a3
BoldRed     = #d80000
BoldGreen   = #30a860
BoldYellow  = #fff018
BoldBlue    = #365eff
BoldMagenta = #9036ff
BoldCyan    = #36d3ff
BoldWhite   = #140c0d

# Background & foreground colors
BackgroundColour = #f0f0f0
ForegroundColour = #4c383b
CursorColour     = #4c383b
