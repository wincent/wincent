# Dark Plus theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #0e0e0e
Red         = #cd3131
Green       = #0dbc79
Yellow      = #3b8eea
Blue        = #2472c8
Magenta     = #bc3fbc
Cyan        = #11a8cd
White       = #c5c5c5
BoldBlack   = #858585
BoldRed     = #f14c4c
BoldGreen   = #23d18b
BoldYellow  = #f5f543
BoldBlue    = #3b8eea
BoldMagenta = #d670d6
BoldCyan    = #29b8db
BoldWhite   = #e5e5e5

# Background & foreground colors
BackgroundColour = #0e0e0e
ForegroundColour = #c5c5c5
CursorColour     = #c5c5c5
