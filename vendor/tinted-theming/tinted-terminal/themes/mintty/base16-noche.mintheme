White       = #cbd4ec
BoldBlack   = #5a6178
BoldRed     = #e2727e
BoldGreen   = #7cc596
BoldYellow  = #d8c062
BoldBlue    = #7aa0e8
BoldMagenta = #b79ae0
BoldCyan    = #6dd8d0
