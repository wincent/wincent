# ENCOM theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #000000
Red         = #9f0000
Green       = #008b00
Yellow      = #0000ff
Blue        = #0081ff
Magenta     = #bc00ca
Cyan        = #008b8b
White       = #a1a1a1
BoldBlack   = #6e6e6e
BoldRed     = #ff0000
BoldGreen   = #00ee00
BoldYellow  = #ffff00
BoldBlue    = #0000ff
BoldMagenta = #ff00ff
BoldCyan    = #00cdcd
BoldWhite   = #ffffff

# Background & foreground colors
BackgroundColour = #000000
ForegroundColour = #a1a1a1
CursorColour     = #a1a1a1
