# Jellybeans theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #121212
Red         = #e27373
Green       = #93b979
Yellow      = #b1d8f6
Blue        = #97bedc
Magenta     = #e1c0fa
Cyan        = #00988e
White       = #d5d5d5
BoldBlack   = #c5c5c5
BoldRed     = #ffa1a1
BoldGreen   = #bddeab
BoldYellow  = #ffdca0
BoldBlue    = #b1d8f6
BoldMagenta = #fbdaff
BoldCyan    = #1ab2a8
BoldWhite   = #ffffff

# Background & foreground colors
BackgroundColour = #121212
ForegroundColour = #d5d5d5
CursorColour     = #d5d5d5
