# Jackie Brown theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #2c1c15
Red         = #ef5734
Green       = #2baf2b
Yellow      = #0000ff
Blue        = #246db2
Magenta     = #cf5ec0
Cyan        = #00acee
White       = #a8a8a8
BoldBlack   = #7c7c7c
BoldRed     = #e50000
BoldGreen   = #86a83e
BoldYellow  = #e5e500
BoldBlue    = #0000ff
BoldMagenta = #e500e5
BoldCyan    = #00e5e5
BoldWhite   = #e5e5e5

# Background & foreground colors
BackgroundColour = #2c1c15
ForegroundColour = #a8a8a8
CursorColour     = #a8a8a8
