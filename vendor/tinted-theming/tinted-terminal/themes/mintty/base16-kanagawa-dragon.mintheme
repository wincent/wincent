# Kanagawa Dragon theme for Mintty
# Scheme Author: Stefan Weigl-Bosker (https://github.com/sweiglbosker), Tommaso Laurenzi (https://github.com/rebelot/kanagawa.nvim)
# Scheme System: base16
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #181616
Red         = #c4746e
Green       = #8a9a7b
Yellow      = #c4b28a
Blue        = #8ba4b0
Magenta     = #a292a3
Cyan        = #8ea4a2
White       = #c5c9c5
BoldBlack   = #625e5a
BoldRed     = #c4746e
BoldGreen   = #8a9a7b
BoldYellow  = #c4b28a
BoldBlue    = #8ba4b0
BoldMagenta = #a292a3
BoldCyan    = #8ea4a2
BoldWhite   = #c5c9c5

# Background & foreground colors
BackgroundColour = #181616
ForegroundColour = #c5c9c5
CursorColour     = #c5c9c5
