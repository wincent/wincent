# Wez theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #000000
Red         = #cc5555
Green       = #55cc55
Yellow      = #5555ff
Blue        = #5455cb
Magenta     = #cc55cc
Cyan        = #7acaca
White       = #aeaeae
BoldBlack   = #727272
BoldRed     = #ff5555
BoldGreen   = #55ff55
BoldYellow  = #ffff55
BoldBlue    = #5555ff
BoldMagenta = #ff55ff
BoldCyan    = #55ffff
BoldWhite   = #ffffff

# Background & foreground colors
BackgroundColour = #000000
ForegroundColour = #aeaeae
CursorColour     = #aeaeae
