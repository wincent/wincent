# Purplepeter theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #2a1a4a
Red         = #ff786c
Green       = #98b481
Yellow      = #79daed
Blue        = #66d9ef
Magenta     = #e68ecd
Cyan        = #b98cff
White       = #c38e69
BoldBlack   = #4b3639
BoldRed     = #f89f92
BoldGreen   = #b4bd8e
BoldYellow  = #f1e9bf
BoldBlue    = #79daed
BoldMagenta = #b991d4
BoldCyan    = #a0a0d6
BoldWhite   = #b9aed3

# Background & foreground colors
BackgroundColour = #2a1a4a
ForegroundColour = #c38e69
CursorColour     = #c38e69
