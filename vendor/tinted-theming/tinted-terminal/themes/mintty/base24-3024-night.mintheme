Blue        = #01a0e4
Magenta     = #a16a94
Cyan        = #b5e4f4
White       = #928f8e
BoldBlack   = #6e6a68
BoldRed     = #e8bbd0
BoldGreen   = #3a3432
BoldYellow  = #4a4543
BoldBlue    = #807d7c
BoldMagenta = #d6d5d4
BoldCyan    = #cdab53
BoldWhite   = #f7f7f7

# Background & foreground colors
BackgroundColour = #090300
ForegroundColour = #928f8e
