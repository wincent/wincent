# Firefox Dev theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #0e1011
Red         = #e63853
Green       = #5eb83c
Yellow      = #006fc0
Blue        = #359ddf
Magenta     = #d75cff
Cyan        = #4b73a2
White       = #a5acae
BoldBlack   = #374d53
BoldRed     = #e1003f
BoldGreen   = #1d9000
BoldYellow  = #cc9308
BoldBlue    = #006fc0
BoldMagenta = #a200da
BoldCyan    = #005794
BoldWhite   = #e2e2e2

# Background & foreground colors
BackgroundColour = #0e1011
ForegroundColour = #a5acae
CursorColour     = #a5acae
