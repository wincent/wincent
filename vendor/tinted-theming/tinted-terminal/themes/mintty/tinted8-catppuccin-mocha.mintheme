# Catppuccin Mocha theme for Mintty
# Scheme Author: https://github.com/catppuccin/catppuccin
# Scheme System: tinted8
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #1e1e2e
Red         = #f38ba8
Green       = #a6e3a1
Yellow      = #f9e2af
Blue        = #89b4fa
Magenta     = #cba6f7
Cyan        = #94e2d5
White       = #cdd6f4
BoldBlack   = #353554
BoldRed     = #f9c2d2
BoldGreen   = #d3f1d0
BoldYellow  = #fcf6e9
BoldBlue    = #c4d9fc
BoldMagenta = #ece0fb
BoldCyan    = #c4efe8
BoldWhite   = #ffffff

# Background & foreground colors
BackgroundColour = #1e1e2e
ForegroundColour = #cdd6f4
CursorColour     = #cdd6f4
