# Arthur theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #1c1c1c
Red         = #cd5c5c
Green       = #86af80
Yellow      = #87ceeb
Blue        = #6495ed
Magenta     = #deb887
Cyan        = #b0c4de
White       = #a19083
BoldBlack   = #6e5d59
BoldRed     = #cc5533
BoldGreen   = #88aa22
BoldYellow  = #ffa75d
BoldBlue    = #87ceeb
BoldMagenta = #996600
BoldCyan    = #b0c4de
BoldWhite   = #ddccbb

# Background & foreground colors
BackgroundColour = #1c1c1c
ForegroundColour = #a19083
CursorColour     = #a19083
