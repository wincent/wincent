# Slate theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #212121
Red         = #e1a7bf
Green       = #80d778
Yellow      = #79afd2
Blue        = #254a49
Magenta     = #a380d3
Cyan        = #14ab9c
White       = #42d3e8
BoldBlack   = #c0f1f8
BoldRed     = #ffccd8
BoldGreen   = #bdffa8
BoldYellow  = #d0cbc9
BoldBlue    = #79afd2
BoldMagenta = #c4a7d8
BoldCyan    = #8bdee0
BoldWhite   = #e0e0e0

# Background & foreground colors
BackgroundColour = #212121
ForegroundColour = #42d3e8
CursorColour     = #42d3e8
