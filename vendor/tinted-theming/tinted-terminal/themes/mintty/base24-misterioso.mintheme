Magenta     = #9413e5
Cyan        = #23d7d7
White       = #bebebd
BoldBlack   = #787877
BoldRed     = #ff3242
BoldGreen   = #74cd68
BoldYellow  = #ffb929
BoldBlue    = #23d7d7
BoldMagenta = #ff37ff
