# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #ffffff
Red         = #b23771
Green       = #66781e
Yellow      = #cda434
Blue        = #3c5ea8
Magenta     = #a454b2
Cyan        = #1e7878
White       = #515151
BoldBlack   = #c1c1c1
BoldRed     = #db3365
BoldGreen   = #829429
BoldYellow  = #cd6f34
BoldBlue    = #3c5ea8
BoldMagenta = #a454b2
BoldCyan    = #175e5e
BoldWhite   = #212121

# Background & foreground colors
BackgroundColour = #ffffff
ForegroundColour = #515151
CursorColour     = #515151
