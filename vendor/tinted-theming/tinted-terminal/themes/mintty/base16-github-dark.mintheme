# Github Dark theme for Mintty
# Scheme Author: Tinted Theming (https://github.com/tinted-theming)
# Scheme System: base16
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #0d1117
Red         = #ffa657
Green       = #a5d6ff
Yellow      = #bb8009
Blue        = #d2a8ff
Magenta     = #ff7b72
Cyan        = #7ee787
White       = #c9d1d9
BoldBlack   = #6e7681
BoldRed     = #ffa657
BoldGreen   = #a5d6ff
BoldYellow  = #bb8009
BoldBlue    = #d2a8ff
BoldMagenta = #ff7b72
BoldCyan    = #7ee787
BoldWhite   = #ffffff

# Background & foreground colors
BackgroundColour = #0d1117
ForegroundColour = #c9d1d9
CursorColour     = #c9d1d9
