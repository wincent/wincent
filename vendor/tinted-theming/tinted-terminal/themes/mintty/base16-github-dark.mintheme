# Github Dark theme for Mintty
# Scheme Author: Tinted Theming (https://github.com/tinted-theming)
# Scheme System: base16
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #161b22
Red         = #f85149
Green       = #2ea043
Yellow      = #bb8009
Blue        = #388bfd
Magenta     = #a371f7
Cyan        = #2a9d9a
White       = #c9d1d9
BoldBlack   = #6e7681
BoldRed     = #f85149
BoldGreen   = #2ea043
BoldYellow  = #bb8009
BoldBlue    = #388bfd
BoldMagenta = #a371f7
BoldCyan    = #2a9d9a
BoldWhite   = #ffffff

# Background & foreground colors
BackgroundColour = #161b22
ForegroundColour = #c9d1d9
CursorColour     = #c9d1d9
