# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #131d42
Red         = #ff4242
Green       = #74af68
Yellow      = #23d7d7
Blue        = #338f86
Magenta     = #9413e5
Cyan        = #23d7d7
White       = #b8beba
BoldBlack   = #66786e
BoldRed     = #ff3242
BoldGreen   = #74cd68
BoldYellow  = #ffb929
BoldBlue    = #23d7d7
BoldMagenta = #ff37ff
BoldCyan    = #00ede1
BoldWhite   = #ffffff

# Background & foreground colors
BackgroundColour = #131d42
ForegroundColour = #b8beba
CursorColour     = #b8beba
