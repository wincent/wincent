# Github Dark Colorblind theme for Mintty
# Scheme Author: Tinted Theming (https://github.com/tinted-theming)
# Scheme System: base16
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #0d1117
Red         = #fdac54
Green       = #a5d6ff
Yellow      = #bb8009
Blue        = #d2a8ff
Magenta     = #ec8e2c
Cyan        = #a5d6ff
White       = #c9d1d9
BoldBlack   = #6e7681
BoldRed     = #fdac54
BoldGreen   = #a5d6ff
BoldYellow  = #bb8009
BoldBlue    = #d2a8ff
BoldMagenta = #ec8e2c
BoldCyan    = #a5d6ff
BoldWhite   = #ffffff

# Background & foreground colors
BackgroundColour = #0d1117
ForegroundColour = #c9d1d9
CursorColour     = #c9d1d9
