# Tango Adapted theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #feffff
Red         = #ff0000
Green       = #59d500
Yellow      = #efca00
Blue        = #00a1ff
Magenta     = #c17ecb
Cyan        = #00d0d6
White       = #4f4f4f
BoldBlack   = #cccccc
BoldRed     = #ff0012
BoldGreen   = #93fe00
BoldYellow  = #fff021
BoldBlue    = #88c9ff
BoldMagenta = #e8a6e1
BoldCyan    = #00fdff
BoldWhite   = #000000

# Background & foreground colors
BackgroundColour = #feffff
ForegroundColour = #4f4f4f
CursorColour     = #4f4f4f
