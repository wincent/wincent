Blue        = #1290bf
Magenta     = #c85e7c
Cyan        = #149b93
White       = #a9a4a8
BoldBlack   = #898388
BoldRed     = #fd8b19
BoldGreen   = #433b42
BoldYellow  = #5c545b
BoldBlue    = #989498
BoldMagenta = #d5d3d5
BoldCyan    = #b33508
BoldWhite   = #ffffff

# Background & foreground colors
BackgroundColour = #322931
ForegroundColour = #a9a4a8
CursorColour     = #a9a4a8
