# Desert theme for Mintty
# Scheme Author: FredHappyface (https://github.com/fredHappyface)
# Scheme System: base24
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #333333
Red         = #ff2b2b
Green       = #98fb98
Yellow      = #87ceff
Blue        = #cd853f
Magenta     = #ffdead
Cyan        = #ffa0a0
White       = #cdbb9b
BoldBlack   = #7d776c
BoldRed     = #ff5555
BoldGreen   = #55ff55
BoldYellow  = #ffff55
BoldBlue    = #87ceff
BoldMagenta = #ff55ff
BoldCyan    = #ffd700
BoldWhite   = #ffffff

# Background & foreground colors
BackgroundColour = #333333
ForegroundColour = #cdbb9b
CursorColour     = #cdbb9b
