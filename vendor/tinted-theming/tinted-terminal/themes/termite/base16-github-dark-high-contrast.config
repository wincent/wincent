[colors]
# base16 Github Dark High Contrast
# Scheme author: Tinted Theming (https://github.com/tinted-theming)
# Template author: Tinted Theming (https://github.com/tinted-theming/tinted-termite)

foreground          = #f0f3f6
foreground_bold     = #f0f3f6
cursor              = #f0f3f6
cursor_foreground   = #0a0c10
background          = #0a0c10

color0  = #0a0c10 # base00 - Black
color1  = #ffb757 # base08 - Red
color2  = #addcff # base0B - Green
color3  = #e09b13 # base0A - Yellow
color4  = #dbb7ff # base0D - Blue
color5  = #ff9492 # base0E - Magenta
color6  = #72f088 # base0C - Cyan
color7  = #f0f3f6 # base05 - White
color8  = #9ea7b3 # base03 - Bright Black
color9  = #ffb757 # base08 - Bright Red
color10 = #addcff # base0B - Bright Green
color11 = #e09b13 # base0A - Bright Yellow
color12 = #dbb7ff # base0D - Bright Blue
color13 = #ff9492 # base0E - Bright Magenta
color14 = #72f088 # base0C - Bright Cyan
color15 = #ffffff # base07 - Bright White
color16 = #91cbff # base09
color17 = #ffb1af # base0F
color18 = #272b33 # base01
color19 = #7a828e # base02
color20 = #bdc4cc # base04
color21 = #ffffff # base06
