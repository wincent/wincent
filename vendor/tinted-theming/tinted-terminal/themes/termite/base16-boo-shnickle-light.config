color8  = #9c9c7d # base03 - Bright Black
color9  = #ffbfa5 # base08 - Bright Red
color10 = #e7ff99 # base0B - Bright Green
color11 = #fff299 # base0A - Bright Yellow
color12 = #bfbfd9 # base0D - Bright Blue
color13 = #f2bfd9 # base0E - Bright Magenta
color14 = #bfffc5 # base0C - Bright Cyan
color15 = #191914 # base07 - Bright White
color16 = #ffdc99 # base09
color17 = #e5d6a6 # base0F
color18 = #dedeb2 # base01
