color6  = #6dd8d0 # base0C - Cyan
color7  = #cbd4ec # base05 - White
color8  = #5a6178 # base03 - Bright Black
color9  = #e2727e # base08 - Bright Red
color10 = #7cc596 # base0B - Bright Green
color11 = #d8c062 # base0A - Bright Yellow
color12 = #7aa0e8 # base0D - Bright Blue
color13 = #b79ae0 # base0E - Bright Magenta
color14 = #6dd8d0 # base0C - Bright Cyan
color15 = #e6ecfa # base07 - Bright White
color16 = #82a6e0 # base09
color17 = #3a4260 # base0F
color18 = #181c2c # base01
