color7  = #d8d6d0 # base05 - White
color8  = #62626a # base03 - Bright Black
color9  = #d0726a # base08 - Bright Red
color10 = #9aa890 # base0B - Bright Green
color11 = #c8b86a # base0A - Bright Yellow
color12 = #8a9ab0 # base0D - Bright Blue
color13 = #b0a0b8 # base0E - Bright Magenta
color14 = #80b8b4 # base0C - Bright Cyan
color15 = #eeece6 # base07 - Bright White
color16 = #e8843a # base09
color17 = #4a4a50 # base0F
