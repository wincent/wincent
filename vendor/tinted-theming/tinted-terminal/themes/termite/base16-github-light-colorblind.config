[colors]
# base16 Github Light Colorblind
# Scheme author: Tinted Theming (https://github.com/tinted-theming)
# Template author: Tinted Theming (https://github.com/tinted-theming/tinted-termite)

foreground          = #424a53
foreground_bold     = #424a53
cursor              = #424a53
cursor_foreground   = #ffffff
background          = #ffffff

color0  = #ffffff # base00 - Black
color1  = #8a4600 # base08 - Red
color2  = #0a3069 # base0B - Green
color3  = #bf8700 # base0A - Yellow
color4  = #8250df # base0D - Blue
color5  = #b35900 # base0E - Magenta
color6  = #0550ae # base0C - Cyan
color7  = #424a53 # base05 - White
color8  = #8c959f # base03 - Bright Black
color9  = #8a4600 # base08 - Bright Red
color10 = #0a3069 # base0B - Bright Green
color11 = #bf8700 # base0A - Bright Yellow
color12 = #8250df # base0D - Bright Blue
color13 = #b35900 # base0E - Bright Magenta
color14 = #0550ae # base0C - Bright Cyan
color15 = #24292f # base07 - Bright White
color16 = #0550ae # base09
color17 = #6f3800 # base0F
color18 = #f6f8fa # base01
color19 = #afb8c1 # base02
color20 = #6e7781 # base04
color21 = #32383f # base06
