[colors]
# base16 Github Dark Dimmed
# Scheme author: Tinted Theming (https://github.com/tinted-theming)
# Template author: Tinted Theming (https://github.com/tinted-theming/tinted-termite)

foreground          = #adbac7
foreground_bold     = #adbac7
cursor              = #adbac7
cursor_foreground   = #22272e
background          = #22272e

color0  = #22272e # base00 - Black
color1  = #f69d50 # base08 - Red
color2  = #96d0ff # base0B - Green
color3  = #ae7c14 # base0A - Yellow
color4  = #dcbdfb # base0D - Blue
color5  = #f47067 # base0E - Magenta
color6  = #8ddb8c # base0C - Cyan
color7  = #adbac7 # base05 - White
color8  = #636e7b # base03 - Bright Black
color9  = #f69d50 # base08 - Bright Red
color10 = #96d0ff # base0B - Bright Green
color11 = #ae7c14 # base0A - Bright Yellow
color12 = #dcbdfb # base0D - Bright Blue
color13 = #f47067 # base0E - Bright Magenta
color14 = #8ddb8c # base0C - Bright Cyan
color15 = #ffffff # base07 - Bright White
color16 = #6cb6ff # base09
color17 = #ff938a # base0F
color18 = #2d333b # base01
color19 = #545d68 # base02
color20 = #768390 # base04
color21 = #cdd9e5 # base06
