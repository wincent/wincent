[colors]
# base24 Github Light High Contrast
# Scheme author: Tinted Theming (https://github.com/tinted-theming)
# Template author: Tinted Theming (https://github.com/tinted-theming/tinted-termite)

foreground          = #343b43
foreground_bold     = #343b43
cursor              = #343b43
cursor_foreground   = #ffffff
background          = #ffffff

color0  = #ffffff # base00 - Black
color1  = #702c00 # base08 - Red
color2  = #032563 # base0B - Green
color3  = #956400 # base0A - Yellow
color4  = #622cbc # base0D - Blue
color5  = #a0111f # base0E - Magenta
color6  = #024c1a # base0C - Cyan
color7  = #343b43 # base05 - White
color8  = #88929d # base03 - Bright Black
color9  = #ee5a5d # base12 - Bright Red
color10 = #26a148 # base14 - Bright Green
color11 = #b58407 # base13 - Bright Yellow
color12 = #368cf9 # base16 - Bright Blue
color13 = #a371f7 # base17 - Bright Magenta
color14 = #49bcb7 # base15 - Bright Cyan
color15 = #0e1116 # base07 - Bright White
color16 = #023b95 # base09
color17 = #6e011a # base0F
color18 = #e7ecf0 # base01
color19 = #acb6c0 # base02
color20 = #66707b # base04
color21 = #20252c # base06
