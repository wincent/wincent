color6  = #2a8a7a # base0C - Cyan
color7  = #3a2e20 # base05 - White
color8  = #9a8c76 # base03 - Bright Black
color9  = #c0392b # base08 - Bright Red
color10 = #5e7a28 # base0B - Bright Green
color11 = #a8761a # base0A - Bright Yellow
color12 = #2c6ca0 # base0D - Bright Blue
color13 = #9b4d8e # base0E - Bright Magenta
color14 = #2a8a7a # base0C - Bright Cyan
color15 = #efe8d8 # base07 - Bright White
color16 = #c25c1f # base09
color17 = #6e6353 # base0F
color18 = #8e8576 # base01
