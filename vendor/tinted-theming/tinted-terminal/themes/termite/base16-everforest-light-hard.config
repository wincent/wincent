[colors]
# base16 Everforest Light (Hard)
# Scheme author: Márcio Sobel (https://github.com/marciosobel)
# Template author: Tinted Theming (https://github.com/tinted-theming/tinted-termite)

foreground          = #5c6a72
foreground_bold     = #5c6a72
cursor              = #5c6a72
cursor_foreground   = #fffbef
background          = #fffbef

color0  = #fffbef # base00 - Black
color1  = #f85552 # base08 - Red
color2  = #8da101 # base0B - Green
color3  = #dfa000 # base0A - Yellow
color4  = #3a94c5 # base0D - Blue
color5  = #df69ba # base0E - Magenta
color6  = #35a77c # base0C - Cyan
color7  = #5c6a72 # base05 - White
color8  = #939f91 # base03 - Bright Black
color9  = #f85552 # base08 - Bright Red
color10 = #8da101 # base0B - Bright Green
color11 = #dfa000 # base0A - Bright Yellow
color12 = #3a94c5 # base0D - Bright Blue
color13 = #df69ba # base0E - Bright Magenta
color14 = #35a77c # base0C - Bright Cyan
color15 = #272e33 # base07 - Bright White
color16 = #f57d26 # base09
color17 = #829181 # base0F
color18 = #f8f5e4 # base01
color19 = #edeada # base02
color20 = #829181 # base04
color21 = #414b50 # base06
