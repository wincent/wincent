[colors]
# base16 Embers Light
# Scheme author: Jannik Siebert (https://github.com/janniks)
# Template author: Tinted Theming (https://github.com/tinted-theming/tinted-termite)

foreground          = #433b32
foreground_bold     = #433b32
cursor              = #433b32
cursor_foreground   = #dbd6d1
background          = #dbd6d1

color0  = #dbd6d1 # base00 - Black
color1  = #826d57 # base08 - Red
color2  = #57826d # base0B - Green
color3  = #6d8257 # base0A - Yellow
color4  = #6d5782 # base0D - Blue
color5  = #82576d # base0E - Magenta
color6  = #576d82 # base0C - Cyan
color7  = #433b32 # base05 - White
color8  = #8a8075 # base03 - Bright Black
color9  = #826d57 # base08 - Bright Red
color10 = #57826d # base0B - Bright Green
color11 = #6d8257 # base0A - Bright Yellow
color12 = #6d5782 # base0D - Bright Blue
color13 = #82576d # base0E - Bright Magenta
color14 = #576d82 # base0C - Bright Cyan
color15 = #16130f # base07 - Bright White
color16 = #828257 # base09
color17 = #825757 # base0F
color18 = #beb6ae # base01
color19 = #a39a90 # base02
color20 = #5a5047 # base04
color21 = #2c2620 # base06
