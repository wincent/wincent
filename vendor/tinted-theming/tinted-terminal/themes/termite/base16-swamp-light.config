[colors]
# base16 Swamp Light
# Scheme author: Masroof Maindak (https://github.com/masroof-maindak)
# Template author: Tinted Theming (https://github.com/tinted-theming/tinted-termite)

foreground          = #64513e
foreground_bold     = #64513e
cursor              = #64513e
cursor_foreground   = #f1e3d1
background          = #f1e3d1

color0  = #f1e3d1 # base00 - Black
color1  = #d09700 # base08 - Red
color2  = #908d6a # base0B - Green
color3  = #993333 # base0A - Yellow
color4  = #bf7979 # base0D - Blue
color5  = #9e5581 # base0E - Magenta
color6  = #d09700 # base0C - Cyan
color7  = #64513e # base05 - White
color8  = #b5a492 # base03 - Bright Black
color9  = #d09700 # base08 - Bright Red
color10 = #908d6a # base0B - Bright Green
color11 = #993333 # base0A - Bright Yellow
color12 = #bf7979 # base0D - Bright Blue
color13 = #9e5581 # base0E - Bright Magenta
color14 = #d09700 # base0C - Bright Cyan
color15 = #8c7b68 # base07 - Bright White
color16 = #64513e # base09
color17 = #75858c # base0F
color18 = #ddcebc # base01
color19 = #c9b9a7 # base02
color20 = #a0907d # base04
color21 = #786653 # base06
