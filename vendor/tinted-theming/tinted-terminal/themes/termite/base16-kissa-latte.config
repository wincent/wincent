[colors]
# base16 Kissa Latte
# Scheme author: rwendell (https://github.com/rwendell/kissa)
# Template author: Tinted Theming (https://github.com/tinted-theming/tinted-termite)

foreground          = #1f1c16
foreground_bold     = #1f1c16
cursor              = #1f1c16
cursor_foreground   = #f5f4f0
background          = #f5f4f0

color0  = #f5f4f0 # base00 - Black
color1  = #9e3e3e # base08 - Red
color2  = #387050 # base0B - Green
color3  = #7d6820 # base0A - Yellow
color4  = #3468a8 # base0D - Blue
color5  = #6438a0 # base0E - Magenta
color6  = #287070 # base0C - Cyan
color7  = #1f1c16 # base05 - White
color8  = #91887d # base03 - Bright Black
color9  = #9e3e3e # base08 - Bright Red
color10 = #387050 # base0B - Bright Green
color11 = #7d6820 # base0A - Bright Yellow
color12 = #3468a8 # base0D - Bright Blue
color13 = #6438a0 # base0E - Bright Magenta
color14 = #287070 # base0C - Bright Cyan
color15 = #fefcfa # base07 - Bright White
color16 = #8f5d22 # base09
color17 = #943a68 # base0F
color18 = #e8e7e3 # base01
color19 = #d5d2cb # base02
color20 = #746c62 # base04
color21 = #6e6459 # base06
