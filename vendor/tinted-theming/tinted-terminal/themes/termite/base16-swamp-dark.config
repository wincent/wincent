color6  = #db930d # base0C - Cyan
color7  = #d2c3a4 # base05 - White
color8  = #5f4e41 # base03 - Bright Black
color9  = #db930d # base08 - Bright Red
color10 = #7a7653 # base0B - Bright Green
color11 = #a82d56 # base0A - Bright Yellow
color12 = #c1666b # base0D - Bright Blue
color13 = #91506c # base0E - Bright Magenta
color14 = #db930d # base0C - Bright Cyan
color15 = #f1e9d0 # base07 - Bright White
