[colors]
# base16 Kissa Macchiato
# Scheme author: rwendell (https://github.com/rwendell/kissa)
# Template author: Tinted Theming (https://github.com/tinted-theming/tinted-termite)

foreground          = #faf0e6
foreground_bold     = #faf0e6
cursor              = #faf0e6
cursor_foreground   = #1f1c16
background          = #1f1c16

color0  = #1f1c16 # base00 - Black
color1  = #e87777 # base08 - Red
color2  = #8cb870 # base0B - Green
color3  = #eac67a # base0A - Yellow
color4  = #7fa8d4 # base0D - Blue
color5  = #b094cc # base0E - Magenta
color6  = #6ab8b0 # base0C - Cyan
color7  = #faf0e6 # base05 - White
color8  = #b8a48c # base03 - Bright Black
color9  = #e87777 # base08 - Bright Red
color10 = #8cb870 # base0B - Bright Green
color11 = #eac67a # base0A - Bright Yellow
color12 = #7fa8d4 # base0D - Bright Blue
color13 = #b094cc # base0E - Bright Magenta
color14 = #6ab8b0 # base0C - Bright Cyan
color15 = #fef4e4 # base07 - Bright White
color16 = #da9050 # base09
color17 = #cc88aa # base0F
color18 = #35322d # base01
color19 = #47443f # base02
color20 = #d4c4a8 # base04
color21 = #e8d5b7 # base06
