color8  = #5c6e5e # base03 - Bright Black
color9  = #e2706a # base08 - Bright Red
color10 = #6fc56e # base0B - Bright Green
color11 = #c8b84a # base0A - Bright Yellow
color12 = #6dae9e # base0D - Bright Blue
