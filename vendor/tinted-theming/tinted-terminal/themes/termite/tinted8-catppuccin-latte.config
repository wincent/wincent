color6  = #179299    # Cyan
color7  = #dce0e8   # White
color8  = #6c6f85   # Bright Black
color9  = #f82653     # Bright Red
color10 = #53d138   # Bright Green
color11 = #eeaa4b  # Bright Yellow
color12 = #598ef8    # Bright Blue
