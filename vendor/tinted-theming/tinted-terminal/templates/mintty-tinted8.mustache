# {{ scheme.name }} theme for Mintty
# Scheme Author: {{ scheme.author }}
# Scheme System: {{ scheme.system }}
# Template Author: Tinted Terminal (https://github.com/tinted-theming/tinted-terminal)

# The 16 color palette
Black       = #{{ palette.black.normal.hex }}
Red         = #{{ palette.red.normal.hex }}
Green       = #{{ palette.green.normal.hex }}
Yellow      = #{{ palette.yellow.normal.hex }}
Blue        = #{{ palette.blue.normal.hex }}
Magenta     = #{{ palette.magenta.normal.hex }}
Cyan        = #{{ palette.cyan.normal.hex }}
White       = #{{ palette.white.normal.hex }}
BoldBlack   = #{{ palette.black.bright.hex }}
BoldRed     = #{{ palette.red.bright.hex }}
BoldGreen   = #{{ palette.green.bright.hex }}
BoldYellow  = #{{ palette.yellow.bright.hex }}
BoldBlue    = #{{ palette.blue.bright.hex }}
BoldMagenta = #{{ palette.magenta.bright.hex }}
BoldCyan    = #{{ palette.cyan.bright.hex }}
BoldWhite   = #{{ palette.white.bright.hex }}

# Background & foreground colors
BackgroundColour = #{{ ui.global.background.normal.hex }}
ForegroundColour = #{{ ui.global.foreground.normal.hex }}
CursorColour     = #{{ ui.cursor.normal.background.hex }}
