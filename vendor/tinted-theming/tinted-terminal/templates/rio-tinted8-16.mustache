# Rio Terminal {{scheme.system}} color theme (https://github.com/tinted-theming)
# Color scheme: {{scheme.name}} by {{scheme-author}}

[colors]
selection-background = '#{{ui.selection.background.hex}}'
selection-foreground = '#{{ui.selection.foreground.hex}}'

cursor         = '#{{ui.cursor.normal.background.hex}}'
tabs           = '#{{palette.black.bright.hex}}'
tabs-active    = '#{{palette.gray.dim.hex}}'

background     = '#{{ui.global.background.normal.hex}}'
foreground     = '#{{ui.global.foreground.normal.hex}}'
black          = '#{{palette.black.normal.hex}}'
red            = '#{{palette.red.normal.hex}}'
yellow         = '#{{palette.yellow.normal.hex}}'
green          = '#{{palette.green.normal.hex}}'
cyan           = '#{{palette.cyan.normal.hex}}'
blue           = '#{{palette.blue.normal.hex}}'
magenta        = '#{{palette.magenta.normal.hex}}'
white          = '#{{palette.white.normal.hex}}'

dim-foreground   = '#{{palette.white.dim.hex}}'
dim-black        = '#{{palette.black.dim.hex}}'
dim-red          = '#{{palette.red.dim.hex}}'
dim-yellow       = '#{{palette.yellow.dim.hex}}'
dim-green        = '#{{palette.green.dim.hex}}'
dim-cyan         = '#{{palette.cyan.dim.hex}}'
dim-blue         = '#{{palette.blue.dim.hex}}'
dim-magenta      = '#{{palette.magenta.dim.hex}}'
dim-white        = '#{{palette.white.dim.hex}}'

light-foreground = '#{{palette.white.bright.hex}}'
light-black      = '#{{palette.black.bright.hex}}'
light-red        = '#{{palette.red.bright.hex}}'
light-yellow     = '#{{palette.yellow.bright.hex}}'
light-green      = '#{{palette.green.bright.hex}}'
light-cyan       = '#{{palette.cyan.bright.hex}}'
light-blue       = '#{{palette.blue.bright.hex}}'
light-magenta    = '#{{palette.magenta.bright.hex}}'
light-white      = '#{{palette.white.bright.hex}}'
