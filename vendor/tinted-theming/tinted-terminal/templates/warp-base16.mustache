# Tinted Terminal {{scheme-system}} color theme (https://github.com/tinted-theming)
# Color scheme: {{scheme-name}} by {{scheme-author}}

name: Base16 {{scheme-name}}
accent: "#{{base0D-hex}}" # base0D
cursor: "#{{base05-hex}}" # base05
background: "#{{base00-hex}}" # base00
foreground: "#{{base05-hex}}" # base05
details: {{#scheme-is-dark-variant}}darker{{/scheme-is-dark-variant}}{{^scheme-is-dark-variant}}lighter{{/scheme-is-dark-variant}}

terminal_colors:
  bright:
    black: "#{{base00-hex}}" # base00
    red: "#{{base08-hex}}" # base08
    yellow: "#{{base0A-hex}}" # base0A
    green: "#{{base0B-hex}}" # base0B
    cyan: "#{{base0C-hex}}" # base0C
    blue: "#{{base0D-hex}}" # base0D
    magenta: "#{{base0E-hex}}" # base0E
    white: "#{{base05-hex}}" # base05

  normal:
    black: "#{{base03-hex}}" # base03
    red: "#{{base08-hex}}" # base08
    yellow: "#{{base0A-hex}}" # base0A
    green: "#{{base0B-hex}}" # base0B
    cyan: "#{{base0C-hex}}" # base0C
    blue: "#{{base0D-hex}}" # base0D
    magenta: "#{{base0E-hex}}" # base0E
    white: "#{{base07-hex}}" # base07
